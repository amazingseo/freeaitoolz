---
import '../styles/global.css';
import { toolCategories } from '../data/tools';
interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  schema?: object;
  faqSchema?: object;
  breadcrumbs?: { label: string; url?: string }[];
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = 'free AI tools, SEO tools, developer tools',
  ogImage = '/og-default.png',
  canonical,
  type = 'website',
  schema,
  faqSchema,
  breadcrumbs,
  noindex = false
} = Astro.props;

const siteUrl = 'https://freeaitoolz.com';
const pageUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.includes('FreeAIToolz') ? title : `${title} | FreeAIToolz`;

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "FreeAIToolz",
  "url": siteUrl,
  "description": "Free AI tools for writing, SEO and developers."
};

const pageSchema = schema || defaultSchema;

/* ADD THIS */

const trendingTools = [
  toolCategories[0].tools[0],
  toolCategories[0].tools[1],
  toolCategories[5].tools[0],
  toolCategories[4].tools[0]
];
---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{fullTitle}</title>

<meta name="description" content={description} />
<meta name="keywords" content={keywords} />

<link rel="canonical" href={pageUrl} />

{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta name="robots" content="index, follow" />

<meta property="og:type" content={type} />
<meta property="og:url" content={pageUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteUrl}${ogImage}`} />

<link rel="icon" href="/favicon.svg" />

<script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

{faqSchema && (
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

</head>

<body class="min-h-screen flex flex-col bg-white">

<!-- Announcement -->

<div class="bg-gray-950 text-gray-400 text-xs py-2 text-center">
All tools are <span class="text-emerald-400 font-bold">100% free</span>
</div>


<nav class="sticky top-0 z-50 backdrop-blur-xl bg-white/70 border-b border-white/40 shadow-sm">

<div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">

<a href="/" class="flex items-center gap-2">
<img src="/favicon.svg" class="w-8 h-8" />
<span class="text-xl font-bold">
Free<span class="text-blue-600">AI</span>Toolz
</span>
</a>

<div class="hidden lg:flex items-center gap-8">

<a href="/" class="font-semibold text-gray-700 hover:text-blue-600">Home</a>


<!-- TOOLS DROPDOWN -->

<div class="relative">

<button
id="toolsButton"
class="flex items-center gap-1 font-semibold text-gray-700 hover:text-blue-600">

Tools

<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round"
d="M19 9l-7 7-7-7"/>
</svg>

</button>


<!-- DROPDOWN -->

<div
id="toolsDropdown"
class="absolute left-1/2 -translate-x-1/2 mt-4 w-[420px] hidden">

<div class="rounded-2xl bg-white shadow-2xl border border-gray-200 p-4">

{toolCategories.map((cat,index)=> (

<div class="mb-2">

<button
class="categoryBtn w-full text-left flex items-center gap-3 px-3 py-3 font-semibold text-gray-800 hover:bg-gray-50 rounded-lg transition"
data-index={index}>

<span class="text-lg">{cat.icon}</span>

<span>{cat.name}</span>

</button>

<div
class="toolList hidden pl-8 pb-2">

{cat.tools.map(tool=> (

<a
href={`/tools/${tool.slug}`}
class="block py-2 text-sm text-gray-600 hover:text-blue-600">

{tool.name}

</a>

))}

</div>

</div>

))}

</div>

</div>

</div>


<a href="/tools" class="font-semibold text-gray-700 hover:text-blue-600">All Tools</a>

<a href="/about" class="font-semibold text-gray-700 hover:text-blue-600">About</a>

</div>

</div>

</nav>

<!-- SEARCH -->

<section class="border-b bg-gray-50 py-6">

<div class="max-w-4xl mx-auto px-4">

<form action="/tools">

<input
type="text"
name="q"
placeholder="Search tools..."
class="w-full border border-gray-200 rounded-xl px-4 py-3"
/>

</form>

</div>

</section>


<!-- TRENDING -->

<section class="py-6 border-b">

<div class="max-w-6xl mx-auto px-4">

<h3 class="text-sm font-semibold text-gray-500 mb-3">
Trending Tools
</h3>

<div class="flex flex-wrap gap-3">

{trendingTools.map(tool => (

<a
href={`/tools/${tool.slug}`}
class="text-sm bg-blue-50 text-blue-600 px-3 py-1 rounded-full hover:bg-blue-100"
>
{tool.name}
</a>

))}

</div>

</div>

</section>


<!-- BREADCRUMBS -->

{breadcrumbs && (

<div class="max-w-7xl mx-auto px-4 mt-6 text-sm text-gray-500">

{breadcrumbs.map((item,i)=>(

<>

{i>0 && <span class="mx-2">›</span>}

{item.url ? (
<a href={item.url} class="hover:text-blue-600">{item.label}</a>
):(
<span>{item.label}</span>
)}

</>

))}

</div>

)}

<main class="flex-1">
<slot />
</main>


<!-- FOOTER -->

<footer class="bg-gray-950 text-gray-400 mt-20">

<div class="max-w-7xl mx-auto px-4 py-10 text-center text-sm">

<p>
© {new Date().getFullYear()} FreeAIToolz — Built by
<a href="https://www.ai2flows.com/" class="text-blue-400">
AI2Flows
</a>
</p>

</div>

</footer>
<script>

const btn = document.getElementById("toolsButton")
const menu = document.getElementById("toolsDropdown")

btn.addEventListener("mouseenter", ()=> menu.classList.remove("hidden"))
menu.addEventListener("mouseenter", ()=> menu.classList.remove("hidden"))

btn.addEventListener("mouseleave", ()=> {
setTimeout(()=> {
if(!menu.matches(":hover")) menu.classList.add("hidden")
},150)
})

menu.addEventListener("mouseleave", ()=> menu.classList.add("hidden"))


const categories = document.querySelectorAll(".categoryBtn")
const lists = document.querySelectorAll(".toolList")

categories.forEach((btn,i)=>{

btn.addEventListener("mouseenter", ()=>{

lists.forEach(l=>l.classList.add("hidden"))

lists[i].classList.remove("hidden")

})

})

</script>
</body>
</html>
