---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  schema?: object;
  faqSchema?: object;
  breadcrumbs?: { label: string; url?: string }[];
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = 'free AI tools, SEO tools, developer tools',
  ogImage = '/og-default.png',
  canonical,
  type = 'website',
  schema,
  faqSchema,
  breadcrumbs,
  noindex = false
} = Astro.props;

const siteUrl = 'https://freeaitoolz.com';
const pageUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.includes('FreeAIToolz') ? title : `${title} | FreeAIToolz`;

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "FreeAIToolz",
  "url": siteUrl,
  "description": "Free AI tools for writing, SEO and developers."
};

const pageSchema = schema || defaultSchema;


/* TOOL CATEGORIES */

const toolCategories = [

{
name: 'AI Writing Tools',
tools: [
{ name:'AI Humanizer', href:'/tools/ai-humanizer' },
{ name:'AI Content Detector', href:'/tools/ai-content-detector' },
{ name:'AI Paraphraser', href:'/tools/ai-paraphraser' },
{ name:'AI Email Writer', href:'/tools/ai-email-writer' }
]
},

{
name: 'SEO Tools',
tools: [
{ name:'Meta Description Generator', href:'/tools/meta-description-generator' },
{ name:'Schema Markup Generator', href:'/tools/schema-markup-generator' },
{ name:'Robots.txt Generator', href:'/tools/robots-txt-generator' },
{ name:'Website Speed Checker', href:'/tools/website-speed-checker' }
]
},

{
name: 'Text Utilities',
tools: [
{ name:'Word Counter', href:'/tools/word-counter' },
{ name:'Case Converter', href:'/tools/case-converter' },
{ name:'Lorem Ipsum Generator', href:'/tools/lorem-ipsum-generator' },
{ name:'Markdown to HTML', href:'/tools/markdown-to-html' }
]
},

{
name: 'Developer Tools',
tools: [
{ name:'JSON Formatter', href:'/tools/json-formatter' },
{ name:'Base64 Encoder Decoder', href:'/tools/base64-encoder-decoder' },
{ name:'CSS Gradient Generator', href:'/tools/css-gradient-generator' },
{ name:'Password Generator', href:'/tools/password-generator' },
{ name:'QR Code Generator', href:'/tools/qr-code-generator' }
]
},

{
name: 'Business Creator Tools',
tools: [
{ name:'SGE Readiness Score', href:'/tools/sge-readiness-score' },
{ name:'SaaS Ghost Calculator', href:'/tools/saas-ghost-calculator' },
{ name:'Content Repurposing Multiplier', href:'/tools/content-repurposing-multiplier' }
]
},

{
name: 'AI Strategy Tools',
tools: [
{ name:'Programmatic SEO Generator', href:'/tools/programmatic-seo-generator' },
{ name:'Vibe Coding Stack Suggester', href:'/tools/vibe-coding-stack-suggester' }
]
}

];

const trendingTools = [
{ name:'AI Humanizer', href:'/tools/ai-humanizer' },
{ name:'AI Content Detector', href:'/tools/ai-content-detector' },
{ name:'Programmatic SEO Generator', href:'/tools/programmatic-seo-generator' },
{ name:'SGE Readiness Score', href:'/tools/sge-readiness-score' }
];
---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{fullTitle}</title>

<meta name="description" content={description} />
<meta name="keywords" content={keywords} />

<link rel="canonical" href={pageUrl} />

{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta name="robots" content="index, follow" />

<meta property="og:type" content={type} />
<meta property="og:url" content={pageUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteUrl}${ogImage}`} />

<link rel="icon" href="/favicon.svg" />

<script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

{faqSchema && (
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

</head>

<body class="min-h-screen flex flex-col bg-white">

<!-- Announcement -->

<div class="bg-gray-950 text-gray-400 text-xs py-2 text-center">
All tools are <span class="text-emerald-400 font-bold">100% free</span>
</div>


<!-- NAVBAR -->

<nav class="bg-white border-b sticky top-0 z-50">

<div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">

<!-- Logo -->

<a href="/" class="flex items-center gap-2">
<img src="/favicon.svg" class="w-8 h-8" />
<span class="text-xl font-bold">
Free<span class="text-blue-600">AI</span>Toolz
</span>
</a>


<div class="hidden lg:flex items-center gap-8">

<a href="/" class="font-semibold hover:text-blue-600">Home</a>


<!-- TOOLS MENU -->

<div class="relative group">

<button class="font-semibold text-gray-700 hover:text-blue-600 flex items-center gap-1">
Tools
<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
</svg>
</button>


<!-- MAIN DROPDOWN -->

<div class="absolute left-0 top-full hidden group-hover:flex bg-white shadow-xl border rounded-xl w-[520px]">

<!-- CATEGORY LIST -->

<div class="w-1/2 border-r bg-gray-50">

{toolCategories.map((cat, i) => (

<div class="relative group/category">

<button class="w-full text-left px-4 py-3 text-sm font-semibold hover:bg-gray-100">

{cat.name}

</button>

<!-- TOOLS PANEL -->

<div class="absolute left-full top-0 hidden group-hover/category:block bg-white shadow-xl border rounded-r-xl w-64 p-4">

<div class="space-y-2">

{cat.tools.map(tool => (

<a
href={tool.href}
class="block text-sm text-gray-600 hover:text-blue-600"
>
{tool.name}
</a>

))}

</div>

</div>

</div>

))}

</div>

</div>

</div>


<a href="/tools" class="font-semibold hover:text-blue-600">
All Tools
</a>

<a href="/about" class="font-semibold hover:text-blue-600">
About
</a>

</div>

</div>

</nav>


<!-- SEARCH -->

<section class="border-b bg-gray-50 py-6">

<div class="max-w-4xl mx-auto px-4">

<form action="/tools">

<input
type="text"
name="q"
placeholder="Search tools..."
class="w-full border border-gray-200 rounded-xl px-4 py-3"
/>

</form>

</div>

</section>


<!-- TRENDING -->

<section class="py-6 border-b">

<div class="max-w-6xl mx-auto px-4">

<h3 class="text-sm font-semibold text-gray-500 mb-3">
Trending Tools
</h3>

<div class="flex flex-wrap gap-3">

{trendingTools.map(tool => (

<a
href={tool.href}
class="text-sm bg-blue-50 text-blue-600 px-3 py-1 rounded-full hover:bg-blue-100"
>
{tool.name}
</a>

))}

</div>

</div>

</section>


<!-- BREADCRUMBS -->

{breadcrumbs && (

<div class="max-w-7xl mx-auto px-4 mt-6 text-sm text-gray-500">

{breadcrumbs.map((item,i)=>(

<>

{i>0 && <span class="mx-2">›</span>}

{item.url ? (
<a href={item.url} class="hover:text-blue-600">{item.label}</a>
):(
<span>{item.label}</span>
)}

</>

))}

</div>

)}

<main class="flex-1">
<slot />
</main>


<!-- FOOTER -->

<footer class="bg-gray-950 text-gray-400 mt-20">

<div class="max-w-7xl mx-auto px-4 py-10 text-center text-sm">

<p>
© {new Date().getFullYear()} FreeAIToolz — Built by
<a href="https://www.ai2flows.com/" class="text-blue-400">
AI2Flows
</a>
</p>

</div>

</footer>

</body>
</html>
