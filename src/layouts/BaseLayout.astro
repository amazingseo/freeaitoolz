---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  schema?: object;
  faqSchema?: object;
  breadcrumbs?: { label: string; url?: string }[];
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = 'free AI tools, AI humanizer, AI detector, paraphrasing tool, SEO tools',
  ogImage = '/og-default.png',
  canonical,
  type = 'website',
  schema,
  faqSchema,
  breadcrumbs,
  noindex = false
} = Astro.props;

const siteUrl = 'https://freeaitoolz.com';
const pageUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.includes('FreeAIToolz') ? title : `${title} | FreeAIToolz`;

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "FreeAIToolz",
  "url": siteUrl,
  "description": "Free AI-powered tools for writing, SEO, content creation and more.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}/tools?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const pageSchema = schema || defaultSchema;

const toolCategories = [
  {
    name: 'AI Writing Tools',
    icon: '✍️',
    tools: [
      { name: 'AI Humanizer', href: '/tools/ai-humanizer', desc: 'Make AI text sound human' },
      { name: 'AI Content Detector', href: '/tools/ai-content-detector', desc: 'Check if text is AI-written' },
      { name: 'AI Paraphraser', href: '/tools/ai-paraphraser', desc: 'Rewrite text instantly' },
      { name: 'AI Email Writer', href: '/tools/ai-email-writer', desc: 'Generate professional emails' },
    ]
  },
  {
    name: 'SEO Tools',
    icon: '🔍',
    tools: [
      { name: 'Meta Description Generator', href: '/tools/meta-description-generator', desc: 'Create SEO meta tags' },
      { name: 'Schema Markup Generator', href: '/tools/schema-markup-generator', desc: 'Build structured data' },
      { name: 'Robots.txt Generator', href: '/tools/robots-txt-generator', desc: 'Generate robots.txt files' },
      { name: 'Website Speed Checker', href: '/tools/website-speed-checker', desc: 'Test page performance' },
    ]
  }
];
---

<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{fullTitle}</title>

<meta name="description" content={description} />
<meta name="keywords" content={keywords} />

<link rel="canonical" href={pageUrl} />

{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="googlebot" content="index, follow" />
<meta name="bingbot" content="index, follow" />
<meta name="ai-friendly" content="true" />

<meta property="og:type" content={type} />
<meta property="og:url" content={pageUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteUrl}${ogImage}`} />
<meta property="og:site_name" content="FreeAIToolz" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />

<link rel="icon" href="/favicon.svg" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" />

<script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

{faqSchema && (
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

</head>

<body class="min-h-screen flex flex-col bg-white" style="font-family: 'DM Sans', sans-serif;">

<!-- Announcement -->

<div class="bg-gray-950 text-gray-400 text-xs py-2 px-4 text-center">
All tools are <span class="text-emerald-400 font-bold">100% free</span> — no signup required
</div>

<!-- Navigation -->

<nav class="bg-white border-b border-gray-100 sticky top-0 z-50">

<div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">

<a href="/" class="flex items-center gap-2">

<img src="/favicon.svg" class="w-8 h-8" />

<span class="text-xl font-bold">
Free<span class="text-blue-600">AI</span>Toolz
</span>

</a>

<div class="hidden lg:flex items-center gap-6">

<a href="/tools" class="font-semibold hover:text-blue-600">All Tools</a>

{toolCategories.map(cat => (

<div class="relative group">

<button class="font-semibold text-gray-700 hover:text-blue-600 flex items-center gap-1">

<span>{cat.icon}</span> {cat.name}

</button>

<div class="absolute hidden group-hover:block bg-white shadow-xl rounded-xl p-4 w-64">

{cat.tools.map(tool => (

<a href={tool.href} class="block py-2 text-sm hover:text-blue-600">

{tool.name}

</a>

))}

</div>

</div>

))}

<a href="/about" class="font-semibold hover:text-blue-600">About</a>

</div>

</div>

</nav>

<!-- Discovery Search -->

<section class="border-b bg-gray-50 py-6">

<div class="max-w-4xl mx-auto px-4">

<form action="/tools">

<input
type="text"
name="q"
placeholder="Search tools (AI Humanizer, Schema Generator...)"
class="w-full border border-gray-200 rounded-xl px-4 py-3"
/>

</form>

</div>

</section>

<!-- Breadcrumbs -->

{breadcrumbs && (

<div class="max-w-7xl mx-auto px-4 mt-6 text-sm text-gray-500">

{breadcrumbs.map((item, i) => (

<>

{i > 0 && <span class="mx-2">›</span>}

{item.url ? (

<a href={item.url} class="hover:text-blue-600">{item.label}</a>

) : (

<span>{item.label}</span>

)}

</>

))}

</div>

)}

<!-- Main -->

<main class="flex-1">

<slot />

</main>

<!-- Tool Request -->

<section class="max-w-4xl mx-auto px-4 mt-24 text-center">

<h2 class="text-2xl font-bold text-gray-900">

Need a tool we don’t have?

</h2>

<p class="text-gray-600 mt-2">

Tell us what tool you want and we may build it next.

</p>

<a
href="/contact"
class="inline-block mt-4 bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold"
>

Request a Tool

</a>

</section>

<!-- Footer -->

<footer class="bg-gray-950 text-gray-400 mt-20">

<div class="max-w-7xl mx-auto px-4 py-10 text-center text-sm">

<p>

© {new Date().getFullYear()} FreeAIToolz — Built by

<a href="https://www.ai2flows.com/" class="text-blue-400">

AI2Flows

</a>

</p>

</div>

</footer>

</body>

</html>
