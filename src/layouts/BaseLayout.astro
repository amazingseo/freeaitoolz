---
import '../styles/global.css';
import { toolCategories } from '../data/tools';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  schema?: object;
  faqSchema?: object;
  breadcrumbs?: { label: string; url?: string }[];
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = 'free AI tools, SEO tools, developer tools',
  ogImage = '/og-default.png',
  canonical,
  type = 'website',
  schema,
  faqSchema,
  breadcrumbs,
  noindex = false
} = Astro.props;

const siteUrl = 'https://www.freeaitoolz.com';
const pageUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.includes('FreeAIToolz') ? title : `${title} | FreeAIToolz`;

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "FreeAIToolz",
  "url": siteUrl,
  "description": "Free AI tools for writing, SEO and developers."
};

const pageSchema = schema || defaultSchema;

const trendingTools = [
  toolCategories[0].tools[0],
  toolCategories[0].tools[1],
  toolCategories[5].tools[0],
  toolCategories[4].tools[0]
];
---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{fullTitle}</title>

<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content="AI2Flows" />
<meta name="publisher" content="FreeAIToolz" />

<link rel="canonical" href={pageUrl} />

{noindex && <meta name="robots" content="noindex,nofollow" />}
<meta name="robots" content="index, follow" />

<meta property="og:type" content={type} />
<meta property="og:url" content={pageUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteUrl}${ogImage}`} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

<link rel="icon" href="/favicon.svg" />

<script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "FreeAIToolz",
  "url": "https://www.freeaitoolz.com",
  "logo": "https://www.freeaitoolz.com/favicon.svg",
  "founder": { "@type": "Organization", "name": "AI2Flows" },
  "sameAs": ["https://www.ai2flows.com"]
})}</script>

</head>

<body class="min-h-screen flex flex-col bg-white">

<!-- Announcement -->

<div class="bg-gray-950 text-gray-400 text-xs py-2 text-center">
All tools are <span class="text-emerald-400 font-bold">100% free</span>
</div>

<!-- NAVBAR -->

<nav class="sticky top-0 z-50 backdrop-blur-xl bg-white/70 border-b border-gray-200/60 shadow-sm">

<div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">

<!-- Logo -->

<a href="/" class="flex items-center gap-2">
<img src="/favicon.svg" class="w-8 h-8" alt="FreeAIToolz logo" />
<span class="text-xl font-bold">
Free<span class="text-blue-600">AI</span>Toolz
</span>
</a>

<!-- Desktop Menu -->

<div class="hidden lg:flex items-center gap-8 text-sm font-semibold">

<a href="/" class="text-gray-700 hover:text-blue-600 transition">
Home
</a>

<!-- Tools Dropdown -->

<div class="relative">

<button
id="toolsButton"
class="flex items-center gap-1 text-gray-700 hover:text-blue-600 transition">

Tools

<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round"
d="M19 9l-7 7-7-7"/>
</svg>

</button>

<!-- Dropdown -->

<div
id="toolsDropdown"
class="absolute left-1/2 -translate-x-1/2 mt-4 w-[380px] hidden opacity-0 scale-95 transition-all duration-200">

<div class="rounded-xl bg-white/90 backdrop-blur-xl shadow-xl border border-gray-200 p-3">
{toolCategories.map((cat,index)=> (

<div class="mb-1">

<button
class="categoryBtn w-full text-left flex items-center gap-3 px-3 py-2 font-semibold text-gray-800 hover:bg-gray-50 rounded-lg transition"
data-index={index}>

<span class="text-lg">{cat.icon}</span>

<span>{cat.name}</span>

</button>

<div class="toolList hidden pl-8 pb-1 space-y-1">

{cat.tools.map(tool=> (

<a
href={`/tools/${tool.slug}`}
class="block py-1 text-sm text-gray-600 hover:text-blue-600 hover:translate-x-1 transition">

{tool.name}

</a>

))}

</div>

</div>

))}

</div>

</div>

</div>

<a href="/tools" class="text-gray-700 hover:text-blue-600 transition">
All Tools
</a>

<a href="/about" class="text-gray-700 hover:text-blue-600 transition">
About
</a>

</div>

<!-- Mobile Button -->

<button
id="mobileMenuBtn"
class="lg:hidden p-2 rounded-lg hover:bg-gray-100">

<svg xmlns="http://www.w3.org/2000/svg"
class="w-6 h-6 text-gray-700"
fill="none"
viewBox="0 0 24 24"
stroke="currentColor">

<path stroke-linecap="round"
stroke-linejoin="round"
stroke-width="2"
d="M4 6h16M4 12h16M4 18h16"/>

</svg>

</button>

</div>

</nav>

<!-- MOBILE MENU -->

<div id="mobileMenu" class="hidden lg:hidden bg-white border-b border-gray-200">

<div class="px-4 py-4 space-y-3">

<a href="/" class="block font-semibold text-gray-700">
Home
</a>

<a href="/tools" class="block font-semibold text-gray-700">
All Tools
</a>

<a href="/about" class="block font-semibold text-gray-700">
About
</a>

</div>

</div>

<!-- SEARCH -->

<section class="border-b bg-gray-50 py-6">

<div class="max-w-4xl mx-auto px-4">

<form action="/tools">

<input
type="text"
name="q"
placeholder="Search tools..."
class="w-full border border-gray-200 rounded-xl px-4 py-3"
/>

</form>

</div>

</section>

<!-- TRENDING -->

<section class="py-6 border-b">

<div class="max-w-6xl mx-auto px-4">

<h3 class="text-sm font-semibold text-gray-500 mb-3">
Trending Tools
</h3>

<div class="flex flex-wrap gap-3">

{trendingTools.map(tool => (

<a
href={`/tools/${tool.slug}`}
class="text-sm bg-blue-50 text-blue-600 px-3 py-1 rounded-full hover:bg-blue-100 transition"
>
{tool.name}
</a>

))}

</div>

</div>

</section>

<!-- BREADCRUMBS -->

{breadcrumbs && (

<div class="max-w-7xl mx-auto px-4 mt-6 text-sm text-gray-500">

{breadcrumbs.map((item,i)=>(

<>

{i>0 && <span class="mx-2">›</span>}

{item.url ? (
<a href={item.url} class="hover:text-blue-600">{item.label}</a>
):(
<span>{item.label}</span>
)}

</>

))}

</div>

)}

<main class="flex-1">
<slot />
</main>

<!-- FOOTER -->

<footer class="bg-gray-950 text-gray-400 mt-20">
  <div class="max-w-7xl mx-auto px-4 py-12">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-gray-800">

      <div>
        <a href="/" class="flex items-center gap-2 mb-3">
          <img src="/favicon.svg" class="w-7 h-7" alt="FreeAIToolz logo" />
          <span class="text-white font-bold text-lg">Free<span class="text-blue-400">AI</span>Toolz</span>
        </a>
        <p class="text-sm text-gray-500 leading-relaxed">
          Free AI tools, SEO utilities and developer tools. No signup required. Everything runs in your browser.
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition">Home</a></li>
          <li><a href="/tools" class="hover:text-white transition">All Tools</a></li>
          <li><a href="/about" class="hover:text-white transition">About</a></li>
          <li><a href="/privacy" class="hover:text-white transition">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-white transition">Terms & Conditions</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Need Custom AI?</h4>
        <a
          href="https://www.ai2flows.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Visit AI2Flows
        </a>
        <p class="text-xs text-gray-500 mt-3">
          Custom AI automations, GHL funnels, chatbots and more.
        </p>
      </div>

    </div>

    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-600">
      <p>© {new Date().getFullYear()} FreeAIToolz. All rights reserved. Built by <a href="https://www.ai2flows.com/" class="text-blue-400 hover:text-blue-300" target="_blank">AI2Flows</a></p>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-gray-400 transition">Privacy Policy</a>
        <a href="/terms" class="hover:text-gray-400 transition">Terms & Conditions</a>
        <a href="/about" class="hover:text-gray-400 transition">About</a>
      </div>
    </div>

  </div>
</footer>
<script>

/* Desktop Dropdown */

const btn = document.getElementById("toolsButton")
const menu = document.getElementById("toolsDropdown")

btn.addEventListener("mouseenter", () => {
menu.classList.remove("hidden","opacity-0","scale-95")
})

menu.addEventListener("mouseenter", () => {
menu.classList.remove("hidden")
})

btn.addEventListener("mouseleave", () => {
setTimeout(() => {
if (!menu.matches(":hover")) {
menu.classList.add("opacity-0","scale-95")
setTimeout(()=>menu.classList.add("hidden"),150)
}
},150)
})

menu.addEventListener("mouseleave", () => {
menu.classList.add("opacity-0","scale-95")
setTimeout(()=>menu.classList.add("hidden"),150)
})

/* Category Hover */

const categories = document.querySelectorAll(".categoryBtn")
const lists = document.querySelectorAll(".toolList")

categories.forEach((btn,i)=>{
btn.addEventListener("mouseenter", ()=>{
lists.forEach(l=>l.classList.add("hidden"))
lists[i].classList.remove("hidden")
})
})

/* Mobile Menu */

const mobileBtn = document.getElementById("mobileMenuBtn")
const mobileMenu = document.getElementById("mobileMenu")

mobileBtn.addEventListener("click", ()=>{
mobileMenu.classList.toggle("hidden")
})

</script>
<!-- Floating CTA Button -->
<div id="floatingCta" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">

  <!-- Tooltip -->
  <div id="ctaTooltip" class="hidden bg-gray-900 text-white text-xs rounded-xl px-4 py-3 shadow-xl max-w-[200px] text-center border border-gray-700">
    <p class="font-semibold text-white mb-1">Need Custom AI Solutions?</p>
    <p class="text-gray-400">GHL funnels, chatbots, automations & more</p>
  </div>

  <!-- Button -->
  <a
    href="https://www.ai2flows.com/"
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm px-5 py-3 rounded-2xl shadow-lg hover:shadow-blue-500/30 transition-all duration-200 hover:scale-105"
    id="ctaBtn"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
    </svg>
    Custom AI Solutions
  </a>

</div>

<script>
  const ctaBtn = document.getElementById('ctaBtn');
  const ctaTooltip = document.getElementById('ctaTooltip');

  ctaBtn.addEventListener('mouseenter', () => {
    ctaTooltip.classList.remove('hidden');
  });

  ctaBtn.addEventListener('mouseleave', () => {
    ctaTooltip.classList.add('hidden');
  });

  // Auto show tooltip once after 3 seconds
  setTimeout(() => {
    ctaTooltip.classList.remove('hidden');
    setTimeout(() => ctaTooltip.classList.add('hidden'), 4000);
  }, 3000);
</script>
</body>
</html>
