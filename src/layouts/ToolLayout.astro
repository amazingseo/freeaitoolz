---
import BaseLayout from './BaseLayout.astro';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  keywords?: string;
  toolName: string;
  toolCategory: string;
  faqs?: FAQ[];
}

const {
  title,
  description,
  keywords = "",
  toolName,
  toolCategory,
  faqs = []
} = Astro.props;

const siteUrl = "https://freeaitoolz.com";
const pageUrl = `${siteUrl}${Astro.url.pathname}`;

/* -------------------------------
   Tool Schema
-------------------------------- */

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": toolName,
  "url": pageUrl,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web Browser",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

/* -------------------------------
   FAQ Schema
-------------------------------- */

const faqSchema = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

/* -------------------------------
   Breadcrumb schema
-------------------------------- */

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools` },
    { "@type": "ListItem", "position": 3, "name": toolName, "item": pageUrl }
  ]
};
---

<BaseLayout
title={title}
description={description}
keywords={keywords}
schema={toolSchema}
faqSchema={faqSchema}
breadcrumbs={[
  { label: "Home", url: "/" },
  { label: "Tools", url: "/tools" },
  { label: toolName }
]}
>

<!-- Additional schema -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<!-- Tool Hero -->

<section class="bg-gradient-to-b from-white to-gray-50 py-10 border-b">

<div class="max-w-5xl mx-auto px-4 text-center">

<div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-4">
{toolCategory} Tool
</div>

<h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">
{toolName}
</h1>

<p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
{description}
</p>

</div>

</section>


<!-- TOOL UI -->

<section class="py-10">

<div class="max-w-5xl mx-auto px-4">

<slot />

</div>

</section>


<!-- QUICK FACTS (AEO Friendly Section) -->

<section class="py-10 bg-gray-50 border-t">

<div class="max-w-4xl mx-auto px-4">

<h2 class="text-2xl font-bold text-gray-900 mb-6">
Quick Facts
</h2>

<div class="overflow-x-auto">

<table class="w-full text-sm border rounded-lg overflow-hidden">

<tbody class="divide-y">

<tr>
<td class="font-semibold p-3">Tool Name</td>
<td class="p-3">{toolName}</td>
</tr>

<tr>
<td class="font-semibold p-3">Category</td>
<td class="p-3">{toolCategory}</td>
</tr>

<tr>
<td class="font-semibold p-3">Price</td>
<td class="p-3">Free</td>
</tr>

<tr>
<td class="font-semibold p-3">Platform</td>
<td class="p-3">Browser Based</td>
</tr>

<tr>
<td class="font-semibold p-3">Login Required</td>
<td class="p-3">No</td>
</tr>

</tbody>

</table>

</div>

</div>

</section>


<!-- HOW TO USE SECTION -->

<section class="py-12">

<div class="max-w-4xl mx-auto px-4">

<h2 class="text-2xl font-bold text-gray-900 mb-4">
How to Use {toolName}
</h2>

<ol class="list-decimal pl-6 space-y-2 text-gray-700">

<li>Enter your input into the tool.</li>

<li>Click the generate or analyze button.</li>

<li>The tool will process your request instantly.</li>

<li>Copy or export the results.</li>

</ol>

</div>

</section>


<!-- RELATED TOOLS (DISCOVERY + INTERNAL SEO) -->

<section class="py-12 bg-gray-50 border-t">

<div class="max-w-5xl mx-auto px-4">

<h2 class="text-2xl font-bold text-gray-900 mb-6">
Related Tools
</h2>

<div class="grid grid-cols-2 md:grid-cols-3 gap-4">

<a href="/tools/ai-humanizer" class="p-4 border rounded-lg hover:border-blue-500">
AI Humanizer
</a>

<a href="/tools/ai-content-detector" class="p-4 border rounded-lg hover:border-blue-500">
AI Content Detector
</a>

<a href="/tools/ai-paraphraser" class="p-4 border rounded-lg hover:border-blue-500">
AI Paraphraser
</a>

<a href="/tools/meta-description-generator" class="p-4 border rounded-lg hover:border-blue-500">
Meta Description Generator
</a>

<a href="/tools/schema-markup-generator" class="p-4 border rounded-lg hover:border-blue-500">
Schema Markup Generator
</a>

<a href="/tools/website-speed-checker" class="p-4 border rounded-lg hover:border-blue-500">
Website Speed Checker
</a>

</div>

</div>

</section>


<!-- FAQ SECTION (AEO Optimized) -->

{faqs.length > 0 && (

<section class="py-12 border-t">

<div class="max-w-3xl mx-auto px-4">

<h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">
Frequently Asked Questions
</h2>

<div class="space-y-4">

{faqs.map((faq, i) => (

<details class="border rounded-lg p-4" open={i === 0}>

<summary class="font-semibold cursor-pointer">
{faq.question}
</summary>

<p class="mt-2 text-gray-600">
{faq.answer}
</p>

</details>

))}

</div>

</div>

</section>

)}

</BaseLayout>
