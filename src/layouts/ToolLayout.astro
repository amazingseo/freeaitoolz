---
import BaseLayout from './BaseLayout.astro';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  keywords?: string;
  toolName: string;
  toolCategory: string;
  faqs?: FAQ[];
}

const {
  title,
  description,
  keywords = "",
  toolName,
  toolCategory,
  faqs = []
} = Astro.props;

const siteUrl = "https://freeaitoolz.com";
const pageUrl = `${siteUrl}${Astro.url.pathname}`;

const toolSchema = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": toolName,
    "url": pageUrl,
    "description": description,
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web Browser",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": toolName,
    "url": pageUrl,
    "description": description,
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web Browser",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
];
const faqSchema = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools` },
    { "@type": "ListItem", "position": 3, "name": toolName, "item": pageUrl }
  ]
};

const categoryGradients = {
  'AI Writing Tool': 'from-violet-600 to-purple-700',
  'SEO Tool': 'from-blue-600 to-cyan-600',
  'Text Utility': 'from-emerald-600 to-teal-600',
  'Developer Tool': 'from-orange-600 to-amber-600',
  'Business & Creator Tool': 'from-pink-600 to-rose-600',
  'AI Strategy Tool': 'from-indigo-600 to-blue-700',
};

const gradient = categoryGradients[toolCategory] || 'from-blue-600 to-violet-600';
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={toolSchema}
  faqSchema={faqSchema}
  breadcrumbs={[
    { label: "Home", url: "/" },
    { label: "Tools", url: "/tools" },
    { label: toolName }
  ]}
>

{toolSchema.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

<!-- TOOL HERO -->
<section class="relative overflow-hidden bg-gray-950 py-12 text-white">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/3 w-72 h-72 bg-blue-600 rounded-full opacity-10 blur-3xl"></div>
    <div class="absolute bottom-0 right-1/3 w-64 h-64 bg-violet-600 rounded-full opacity-10 blur-3xl"></div>
  </div>
  <div class="relative max-w-4xl mx-auto px-4 text-center">
    <div class={`inline-flex items-center gap-2 bg-gradient-to-r ${gradient} text-white px-4 py-1.5 rounded-full text-xs font-bold mb-5 shadow-sm`}>
      {toolCategory}
    </div>
    <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">
      {toolName}
    </h1>
    <p class="mt-4 text-gray-400 max-w-2xl mx-auto text-base leading-relaxed">
      {description}
    </p>
    <!-- Trust badges -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
      {[
        { icon: '✅', text: 'Free Forever' },
        { icon: '🔒', text: 'No Signup' },
        { icon: '⚡', text: 'Instant Results' },
        { icon: '🌐', text: 'Browser Based' },
      ].map(badge => (
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">
          {badge.icon} {badge.text}
        </span>
      ))}
    </div>
  </div>
</section>

<!-- TOOL INTERFACE -->
<section class="py-10 bg-white">
  <div class="max-w-5xl mx-auto px-4">
    <slot />
  </div>
</section>

<!-- QUICK FACTS -->
<section class="w-full bg-gray-50 border-t border-b border-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-12">

    <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/>
      </svg>
      Quick Facts
    </h2>

    <div class="divide-y divide-gray-200">

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-4.75M16 3l5 5-9 9H7v-5l9-9z"/>
          </svg>
          Tool Name
        </span>
        <span class="text-sm font-semibold text-gray-800">{toolName}</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
          </svg>
          Category
        </span>
        <span class={`text-sm font-semibold text-white bg-gradient-to-r ${gradient} px-3 py-1 rounded-full`}>{toolCategory}</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.12-3 2.5S10.343 13 12 13s3 1.12 3 2.5S13.657 18 12 18m0-10V6m0 12v-2"/>
          </svg>
          Price
        </span>
        <span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">✓ Free</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Platform
        </span>
        <span class="text-sm font-semibold text-gray-800">Browser Based</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/>
          </svg>
          Login Required
        </span>
        <span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">✓ No</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Processing
        </span>
        <span class="text-sm font-semibold text-gray-800">Instant</span>
      </div>

    </div>
  </div>
</section>

<!-- HOW TO USE -->
<section class="py-14 bg-white">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-2xl font-extrabold text-gray-900 mb-8">
      How to Use {toolName}
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { n: '1', title: 'Enter Your Input', desc: 'Paste your text or fill in the required fields in the tool above.' },
        { n: '2', title: 'Click Generate', desc: 'Hit the generate or analyze button to start processing.' },
        { n: '3', title: 'Get Instant Results', desc: 'The tool processes your input instantly in your browser.' },
        { n: '4', title: 'Copy or Export', desc: 'Copy your results to clipboard or download the output.' },
      ].map(step => (
        <div class="flex flex-col items-start gap-3">
          <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${gradient} text-white flex items-center justify-center font-bold text-lg shrink-0 shadow-sm`}>
            {step.n}
          </div>
          <div>
            <p class="font-bold text-gray-900 text-sm">{step.title}</p>
            <p class="text-sm text-gray-500 mt-1 leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SLOT for SEO content + Related Tools from individual tool pages -->
<div class="bg-gray-50 border-t border-gray-100">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <slot name="content" />
  </div>
</div>

<!-- FAQ -->
{faqs.length > 0 && (
<section class="py-14 bg-white border-t border-gray-100">
  <div class="max-w-3xl mx-auto px-4">

    <h2 class="text-2xl font-extrabold text-gray-900 mb-2 text-center">
      Frequently Asked Questions
    </h2>
    <p class="text-gray-500 text-sm text-center mb-8">Everything you need to know about {toolName}</p>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details class="group border border-gray-200 rounded-2xl overflow-hidden bg-white hover:border-blue-200 transition-colors" open={i === 0}>
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-semibold text-gray-900 text-sm list-none select-none">
            <span>{faq.question}</span>
            <svg class="w-4 h-4 text-gray-400 shrink-0 ml-3 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>

  </div>
</section>
)}

<!-- BOTTOM CTA -->
<section class="py-12 bg-gray-950 text-white">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <p class="text-gray-400 text-sm mb-4">Need more than free tools?</p>
    <a
      href="https://www.ai2flows.com/"
      target="_blank"
      rel="noopener noreferrer"
      class={`inline-flex items-center gap-2 bg-gradient-to-r ${gradient} text-white font-bold px-7 py-3.5 rounded-xl transition-all hover:scale-105 shadow-lg text-sm`}
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      Get Custom AI Solutions from AI2Flows
    </a>
  </div>
</section>

</BaseLayout>
