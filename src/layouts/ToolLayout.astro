---
import BaseLayout from './BaseLayout.astro';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  keywords?: string;
  toolName: string;
  toolCategory: string;
  faqs?: FAQ[];
}

const {
  title,
  description,
  keywords = "",
  toolName,
  toolCategory,
  faqs = []
} = Astro.props;

const siteUrl = "https://freeaitoolz.com";
const pageUrl = `${siteUrl}${Astro.url.pathname}`;

/* -------------------------------
   Tool Schema
-------------------------------- */

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": toolName,
  "url": pageUrl,
  "description": description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web Browser",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

/* -------------------------------
   FAQ Schema
-------------------------------- */

const faqSchema = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

/* -------------------------------
   Breadcrumb schema
-------------------------------- */

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools` },
    { "@type": "ListItem", "position": 3, "name": toolName, "item": pageUrl }
  ]
};
---

<BaseLayout
title={title}
description={description}
keywords={keywords}
schema={toolSchema}
faqSchema={faqSchema}
breadcrumbs={[
  { label: "Home", url: "/" },
  { label: "Tools", url: "/tools" },
  { label: toolName }
]}
>

<!-- Additional schema -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<!-- Tool Hero -->

<section class="bg-gradient-to-b from-white to-gray-50 py-10 border-b">

<div class="max-w-5xl mx-auto px-4 text-center">

<div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-4">
{toolCategory} Tool
</div>

<h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">
{toolName}
</h1>

<p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
{description}
</p>

</div>

</section>


<!-- TOOL UI -->

<section class="py-10">

<div class="max-w-5xl mx-auto px-4">

<slot />

</div>

</section>


<!-- QUICK FACTS (AEO Friendly Section) -->
<section class="w-full bg-gray-50 border-t border-b border-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-12">

    <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/>
      </svg>
      Quick Facts
    </h2>

    <div class="divide-y divide-gray-200">

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-4.75M16 3l5 5-9 9H7v-5l9-9z"/>
          </svg>
          Tool Name
        </span>
        <span class="text-sm font-semibold text-gray-800">{toolName}</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
          </svg>
          Category
        </span>
        <span class="text-sm font-semibold text-blue-600 bg-blue-50 px-3 py-1 rounded-full">{toolCategory}</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.12-3 2.5S10.343 13 12 13s3 1.12 3 2.5S13.657 18 12 18m0-10V6m0 12v-2"/>
          </svg>
          Price
        </span>
        <span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">✓ Free</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Platform
        </span>
        <span class="text-sm font-semibold text-gray-800">Browser Based</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/>
          </svg>
          Login Required
        </span>
        <span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">✓ No</span>
      </div>

      <div class="flex items-center justify-between py-3">
        <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Processing
        </span>
        <span class="text-sm font-semibold text-gray-800">Instant</span>
      </div>

    </div>
  </div>
</section>

<!-- HOW TO USE SECTION -->
<section class="py-12 bg-white">
  <div class="max-w-4xl mx-auto px-4">

    <h2 class="text-2xl font-bold text-gray-900 mb-8">
      How to Use {toolName}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <div class="flex flex-col items-start gap-3">
        <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg shrink-0">
          1
        </div>
        <div>
          <p class="font-semibold text-gray-900 text-sm">Enter Your Input</p>
          <p class="text-sm text-gray-500 mt-1">Paste your text or fill in the required fields in the tool above.</p>
        </div>
      </div>

      <div class="flex flex-col items-start gap-3">
        <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg shrink-0">
          2
        </div>
        <div>
          <p class="font-semibold text-gray-900 text-sm">Click Generate</p>
          <p class="text-sm text-gray-500 mt-1">Hit the generate or analyze button to start processing your request.</p>
        </div>
      </div>

      <div class="flex flex-col items-start gap-3">
        <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg shrink-0">
          3
        </div>
        <div>
          <p class="font-semibold text-gray-900 text-sm">Get Instant Results</p>
          <p class="text-sm text-gray-500 mt-1">The tool processes your input instantly, right in your browser.</p>
        </div>
      </div>

      <div class="flex flex-col items-start gap-3">
        <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg shrink-0">
          4
        </div>
        <div>
          <p class="font-semibold text-gray-900 text-sm">Copy or Export</p>
          <p class="text-sm text-gray-500 mt-1">Copy your results to clipboard or download the output for use.</p>
        </div>
      </div>

    </div>

  </div>
</section>


<!-- FAQ SECTION (AEO Optimized) -->

{faqs.length > 0 && (

<section class="py-12 border-t">

<div class="max-w-3xl mx-auto px-4">

<h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">
Frequently Asked Questions
</h2>

<div class="space-y-4">

{faqs.map((faq, i) => (

<details class="border rounded-lg p-4" open={i === 0}>

<summary class="font-semibold cursor-pointer">
{faq.question}
</summary>

<p class="mt-2 text-gray-600">
{faq.answer}
</p>

</details>

))}

</div>

</div>

</section>

)}

</BaseLayout>
