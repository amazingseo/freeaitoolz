---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const writingTools = [
  { name: 'AI Humanizer', desc: 'Transform AI-generated text into natural, human-sounding writing.', href: '/tools/ai-humanizer', icon: '✍️', badge: 'Most Popular' },
  { name: 'AI Content Detector', desc: 'Check if any text was written by AI with confidence scores.', href: '/tools/ai-content-detector', icon: '🔍', badge: 'New' },
  { name: 'AI Paraphraser', desc: 'Rewrite any text in seconds. 6 styles available.', href: '/tools/ai-paraphraser', icon: '🔄', badge: 'Unlimited' },
  { name: 'AI Email Writer', desc: 'Generate professional emails for any business situation.', href: '/tools/ai-email-writer', icon: '📧', badge: 'Business' },
];

const seoTools = [
  { name: 'Meta Description Generator', desc: 'Generate SEO-optimized meta descriptions and title tags.', href: '/tools/meta-description-generator', icon: '🏷️', badge: 'SEO' },
  { name: 'Schema Markup Generator', desc: 'Build JSON-LD structured data for rich Google results.', href: '/tools/schema-markup-generator', icon: '🔧', badge: 'New' },
  { name: 'Website Speed Checker', desc: 'Test Core Web Vitals, performance, and SEO scores.', href: '/tools/website-speed-checker', icon: '⚡', badge: 'New' },
];
---

<BaseLayout
  title="Free AI Tools Online - AI Humanizer, Paraphraser, Detector, SEO Tools | FreeAIToolz"
  description="100% free AI tools for writing, SEO, and content creation. AI Humanizer, Content Detector, Paraphraser, Schema Generator, Speed Checker and more. No signup required."
  keywords="free AI tools, AI humanizer, AI content detector, paraphrasing tool, schema generator, website speed checker, free SEO tools"
>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0A0F1C 0%, #111827 50%, #0A0F1C 100%);">
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 50%, #1d4ed8 0%, transparent 50%), radial-gradient(circle at 80% 50%, #7c3aed 0%, transparent 50%);"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 sm:py-28 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-medium text-blue-200 border border-white/10 mb-8">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
        8 free tools — no signup, no limits
      </div>
      
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-[1.1]">
        AI Tools That Actually
        <span class="block mt-2" style="background: linear-gradient(135deg, #60a5fa, #a78bfa, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Work. For Free.</span>
      </h1>
      
      <p class="mt-6 text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Humanize AI text, detect AI content, paraphrase anything, generate schema markup, check site speed — all powered by AI, all completely free.
      </p>
      
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/tools/ai-humanizer" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-4 rounded-xl text-lg transition-all shadow-lg hover:shadow-blue-500/25">
          Try AI Humanizer
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
        <a href="/tools" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 text-white font-bold px-8 py-4 rounded-xl text-lg border border-white/20 transition-all">
          Browse All Tools
        </a>
      </div>

      <div class="mt-14 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm text-gray-400">
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>No signup required</span>
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>No word limits</span>
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>Private & secure</span>
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>AI-powered accuracy</span>
      </div>
    </div>
  </section>

  <!-- AI Writing Tools -->
  <section class="py-20" id="tools">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">✍️</span>
        <div>
          <h2 class="text-3xl font-extrabold text-gray-900">AI Writing Tools</h2>
          <p class="text-gray-500 mt-1">AI-powered tools for content creation and editing</p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {writingTools.map(tool => (
          <a href={tool.href} class="tool-card group flex flex-col">
            <div class="flex items-start justify-between mb-3">
              <span class="text-3xl">{tool.icon}</span>
              <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-blue-100 text-blue-700">{tool.badge}</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{tool.name}</h3>
            <p class="mt-1.5 text-sm text-gray-500 flex-1">{tool.desc}</p>
            <div class="mt-4 text-sm font-bold text-blue-600 flex items-center gap-1">
              Use Free <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SEO Tools -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-2xl">🔍</span>
        <div>
          <h2 class="text-3xl font-extrabold text-gray-900">SEO Tools</h2>
          <p class="text-gray-500 mt-1">Essential tools for search engine optimization</p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {seoTools.map(tool => (
          <a href={tool.href} class="tool-card group flex flex-col">
            <div class="flex items-start justify-between mb-3">
              <span class="text-3xl">{tool.icon}</span>
              <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-blue-100 text-blue-700">{tool.badge}</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{tool.name}</h3>
            <p class="mt-1.5 text-sm text-gray-500 flex-1">{tool.desc}</p>
            <div class="mt-4 text-sm font-bold text-blue-600 flex items-center gap-1">
              Use Free <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-extrabold text-gray-900 mb-12">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-extrabold text-blue-600">1</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900">Choose Your Tool</h3>
          <p class="mt-2 text-sm text-gray-500">Pick from 8 free AI-powered tools for writing, SEO, and content creation.</p>
        </div>
        <div>
          <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-extrabold text-blue-600">2</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900">Enter Your Content</h3>
          <p class="mt-2 text-sm text-gray-500">Paste text or enter your data. No account needed, no limits.</p>
        </div>
        <div>
          <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-extrabold text-blue-600">3</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900">Get Instant Results</h3>
          <p class="mt-2 text-sm text-gray-500">AI processes your request in seconds. Copy and use anywhere.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-950 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Need Custom AI Automation?</h2>
      <p class="mt-4 text-lg text-gray-300 max-w-2xl mx-auto">FreeAIToolz is built by AI2Flows — a full-service AI automation agency. We build GoHighLevel workflows, AI chatbots, Meta & Google Ads campaigns, and custom integrations for growing businesses.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://www.ai2flows.com/" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-4 rounded-xl text-lg transition-all">
          Visit AI2Flows →
        </a>
        <a href="/about" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 text-white font-bold px-8 py-4 rounded-xl text-lg border border-white/20 transition-all">
          Learn About Our Team
        </a>
      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 prose-custom">
      <h2>Why Use FreeAIToolz?</h2>
      <p>FreeAIToolz provides a comprehensive suite of AI-powered writing and SEO tools that are completely free to use. Whether you need to humanize AI-generated content, detect if text was written by AI, paraphrase paragraphs, generate SEO metadata, write professional emails, create schema markup, or check website performance — our tools deliver fast, accurate results without requiring any signup or payment.</p>
      <p>Every tool runs with enterprise-grade AI and is designed for speed, privacy, and accuracy. Your text is never stored on our servers. We built these tools for students, bloggers, marketers, SEO professionals, and anyone who works with written content daily.</p>
    </div>
  </section>

</BaseLayout>