---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    name: 'AI Humanizer',
    desc: 'Transform AI-generated text into natural, human-sounding writing that bypasses AI detectors.',
    href: '/tools/ai-humanizer',
    icon: '✍️',
    badge: 'Most Popular',
    badgeColor: 'bg-green-100 text-green-700',
  },
  {
    name: 'AI Content Detector',
    desc: 'Check if any text was written by AI. Instant analysis with detailed confidence scores.',
    href: '/tools/ai-content-detector',
    icon: '🔍',
    badge: 'New',
    badgeColor: 'bg-blue-100 text-blue-700',
  },
  {
    name: 'AI Paraphraser',
    desc: 'Rewrite any text in seconds. Multiple tones available. No word limits, no signup.',
    href: '/tools/ai-paraphraser',
    icon: '🔄',
    badge: 'Unlimited',
    badgeColor: 'bg-purple-100 text-purple-700',
  },
  {
    name: 'Meta Description Generator',
    desc: 'Generate SEO-optimized meta descriptions and title tags for any webpage in seconds.',
    href: '/tools/meta-description-generator',
    icon: '🏷️',
    badge: 'SEO',
    badgeColor: 'bg-orange-100 text-orange-700',
  },
  {
    name: 'AI Email Writer',
    desc: 'Write professional emails, cold outreach, and follow-ups with AI. Multiple templates.',
    href: '/tools/ai-email-writer',
    icon: '📧',
    badge: 'Business',
    badgeColor: 'bg-rose-100 text-rose-700',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "FreeAIToolz",
  "url": "https://freeaitoolz.com",
  "description": "Free AI-powered tools for writing, SEO, content creation, and more. No signup required.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://freeaitoolz.com/tools?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout
  title="Free AI Tools Online - AI Humanizer, Paraphraser, Detector & More | FreeAIToolz"
  description="100% free AI tools for writing, SEO, and content creation. AI Humanizer, Content Detector, Paraphraser, Meta Description Generator, Email Writer. No signup required."
  keywords="free AI tools, AI humanizer, AI content detector, AI paraphrasing tool, free AI writing tools online, meta description generator, AI email writer"
  schema={schema}
>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800 text-white py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-medium mb-6 border border-white/20">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        All tools are 100% free — no signup, no limits
      </div>
      
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
        Free AI Tools for<br />
        <span class="bg-gradient-to-r from-blue-300 to-cyan-300 bg-clip-text text-transparent">Smarter Writing & SEO</span>
      </h1>
      
      <p class="mt-6 text-lg sm:text-xl text-blue-100 max-w-2xl mx-auto leading-relaxed">
        Humanize AI text, detect AI content, paraphrase anything, generate meta descriptions, and write professional emails — all powered by AI, all completely free.
      </p>
      
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/tools/ai-humanizer" class="btn-primary text-lg px-8 py-4 inline-flex items-center justify-center gap-2">
          Try AI Humanizer
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="/tools" class="btn-secondary text-lg px-8 py-4 bg-white/10 hover:bg-white/20 text-white border border-white/20 inline-flex items-center justify-center">
          Browse All Tools
        </a>
      </div>

      <!-- Trust signals -->
      <div class="mt-12 flex flex-wrap justify-center gap-8 text-sm text-blue-200">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          No signup required
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          No word limits
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          Works on all devices
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          AI-powered accuracy
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Grid -->
  <section class="py-16 sm:py-20" id="tools">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900">Our Free AI Tools</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-xl mx-auto">Choose from our growing collection of AI-powered tools designed to save you time and improve your content.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tools.map(tool => (
          <a href={tool.href} class="tool-card group cursor-pointer flex flex-col">
            <div class="flex items-start justify-between mb-4">
              <span class="text-3xl">{tool.icon}</span>
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${tool.badgeColor}`}>{tool.badge}</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 group-hover:text-brand-600 transition-colors">{tool.name}</h3>
            <p class="mt-2 text-gray-600 text-sm leading-relaxed flex-1">{tool.desc}</p>
            <div class="mt-4 flex items-center gap-1.5 text-brand-600 font-semibold text-sm">
              Use Tool Free
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </a>
        ))}

        <!-- Coming soon card -->
        <div class="tool-card opacity-60 flex flex-col items-center justify-center text-center py-10">
          <span class="text-3xl mb-3">🚀</span>
          <h3 class="text-lg font-bold text-gray-700">More Tools Coming Soon</h3>
          <p class="mt-1 text-gray-500 text-sm">New AI tools added every week</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-white border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-12">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-brand-600">1</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900">Choose Your Tool</h3>
          <p class="mt-2 text-gray-600 text-sm">Pick from our collection of free AI-powered tools for writing, SEO, and content creation.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-brand-600">2</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900">Paste Your Text</h3>
          <p class="mt-2 text-gray-600 text-sm">Enter or paste your content. No account needed, no limits on usage, no hidden fees.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-brand-600">3</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900">Get AI Results</h3>
          <p class="mt-2 text-gray-600 text-sm">Our AI processes your text instantly. Copy the results and use them anywhere you need.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Content Section -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Why Use FreeAIToolz?</h2>
      <div class="prose prose-gray max-w-none text-gray-600 leading-relaxed space-y-4">
        <p>FreeAIToolz provides a comprehensive suite of AI-powered writing and SEO tools that are completely free to use. Whether you need to humanize AI-generated content, detect if text was written by AI, paraphrase paragraphs, generate SEO metadata, or write professional emails, our tools deliver fast, accurate results without requiring any signup or payment.</p>
        <p>Every tool runs directly in your browser for maximum privacy and speed. Your text is never stored on our servers. We built these tools for students, bloggers, marketers, SEO professionals, and anyone who works with written content daily.</p>
        <p>Our AI tools are updated regularly to keep up with the latest language models and detection algorithms, ensuring you always get the best possible results. From academic writing to business communications to content marketing, FreeAIToolz has the right tool for every writing task.</p>
      </div>
    </div>
  </section>

</BaseLayout>
