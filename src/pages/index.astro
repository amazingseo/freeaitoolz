---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { toolCategories } from '../data/tools';

const totalTools = toolCategories.reduce((sum, c) => sum + c.tools.length, 0);

const categoriesWithUrls = toolCategories.map(cat => ({
  name: cat.name,
  icon: cat.icon,
  tools: cat.tools.map(tool => ({
    name: tool.name,
    description: tool.description,
    slug: tool.slug,
    href: '/tools/' + tool.slug
  }))
}));

const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "FreeAIToolz",
  "description": "Free AI tools, SEO tools, and developer utilities",
  "url": "https://freeaitoolz.com"
};

const totalLabel = String(totalTools) + '+';

const stats = [
  { number: totalLabel, label: 'Free Tools' },
  { number: '100%', label: 'Free Forever' },
  { number: '0', label: 'Signup Needed' },
  { number: '6', label: 'Categories' },
];

const categoryColors = {
  'AI Writing Tools': 'from-violet-500 to-purple-600',
  'SEO Tools': 'from-blue-500 to-cyan-500',
  'Text Utilities': 'from-emerald-500 to-teal-500',
  'Developer Tools': 'from-orange-500 to-amber-500',
  'Business Creator Tools': 'from-pink-500 to-rose-500',
  'AI Strategy Tools': 'from-indigo-500 to-blue-600',
};

const categoryBg = {
  'AI Writing Tools': 'bg-violet-50 border-violet-100',
  'SEO Tools': 'bg-blue-50 border-blue-100',
  'Text Utilities': 'bg-emerald-50 border-emerald-100',
  'Developer Tools': 'bg-orange-50 border-orange-100',
  'Business Creator Tools': 'bg-pink-50 border-pink-100',
  'AI Strategy Tools': 'bg-indigo-50 border-indigo-100',
};

const categoryAccent = {
  'AI Writing Tools': 'text-violet-600 group-hover:text-violet-700',
  'SEO Tools': 'text-blue-600 group-hover:text-blue-700',
  'Text Utilities': 'text-emerald-600 group-hover:text-emerald-700',
  'Developer Tools': 'text-orange-600 group-hover:text-orange-700',
  'Business Creator Tools': 'text-pink-600 group-hover:text-pink-700',
  'AI Strategy Tools': 'text-indigo-600 group-hover:text-indigo-700',
};
---

<BaseLayout
  title={`${totalTools}+ Free AI Tools, SEO Tools & Developer Tools | FreeAIToolz`}
  description={`Discover ${totalTools}+ free online AI tools, SEO tools and developer utilities. AI Humanizer, Content Detector, JSON Formatter and more. No signup required.`}
  keywords="free ai tools, seo tools online, developer tools free, ai humanizer, json formatter"
  schema={homepageSchema}
>

<!-- HERO -->
<section class="relative overflow-hidden bg-gray-950 py-24 text-white">

  <!-- Background gradient mesh -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-600 rounded-full opacity-10 blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-violet-600 rounded-full opacity-10 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[200px] bg-blue-500 rounded-full opacity-5 blur-3xl"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-4 text-center">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/20 text-blue-400 px-4 py-1.5 rounded-full text-sm font-semibold mb-8">
      <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
      {totalTools}+ Tools — Always Free
    </div>

    <h1 class="text-5xl sm:text-6xl font-extrabold leading-tight tracking-tight">
      Free AI Tools That
      <span class="bg-gradient-to-r from-blue-400 via-violet-400 to-cyan-400 bg-clip-text text-transparent"> Actually Work</span>
    </h1>

    <p class="mt-6 text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
      Browse {totalTools}+ powerful browser-based tools for AI writing, SEO optimization,
      text editing and development. No signup, no limits, no cost.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/tools/ai-humanizer" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-4 rounded-xl transition-all hover:scale-105 shadow-lg shadow-blue-500/20">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
        </svg>
        Try AI Humanizer
      </a>
      <a href="/tools" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 border border-white/10 text-white font-semibold px-8 py-4 rounded-xl transition-all">
        Browse All Tools →
      </a>
    </div>

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-2xl mx-auto">
      {stats.map(s => (
        <div class="bg-white/5 border border-white/10 rounded-2xl py-4 px-3">
          <div class="text-2xl font-extrabold text-white">{s.number}</div>
          <div class="text-xs text-gray-500 mt-0.5 font-medium">{s.label}</div>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- SEARCH -->
<section class="py-10 bg-white border-b border-gray-100 sticky top-16 z-40 shadow-sm">
  <div class="max-w-2xl mx-auto px-4">
    <div class="relative">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input
        type="text"
        placeholder="Search tools (AI Humanizer, JSON Formatter, QR Code...)"
        class="w-full pl-12 pr-4 py-3.5 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-gray-50 hover:bg-white transition"
      />
    </div>
  </div>
</section>

<!-- POPULAR TOOLS -->
<section class="py-16 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">

    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-extrabold text-gray-900">🔥 Popular Tools</h2>
        <p class="text-sm text-gray-500 mt-1">Most used by our community</p>
      </div>
      <a href="/tools" class="text-sm font-semibold text-blue-600 hover:text-blue-700 transition">
        View all →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { name: 'AI Humanizer', desc: 'Transform AI text to human writing', href: '/tools/ai-humanizer', icon: '✍️', gradient: 'from-violet-500 to-purple-600' },
        { name: 'AI Content Detector', desc: 'Detect AI generated content instantly', href: '/tools/ai-content-detector', icon: '🔍', gradient: 'from-blue-500 to-cyan-500' },
        { name: 'Internal Link Suggester', desc: 'Find SEO link opportunities fast', href: '/tools/internal-link-suggester', icon: '🔗', gradient: 'from-emerald-500 to-teal-500' },
        { name: 'Meta Description Generator', desc: 'Generate optimized meta descriptions', href: '/tools/meta-description-generator', icon: '🏷️', gradient: 'from-orange-500 to-amber-500' },
      ].map(tool => (
        <a href={tool.href} class="group relative bg-white border border-gray-200 rounded-2xl p-5 hover:border-transparent hover:shadow-xl transition-all duration-200 overflow-hidden">
          <div class={`absolute inset-0 bg-gradient-to-br ${tool.gradient} opacity-0 group-hover:opacity-5 transition-opacity duration-200`}></div>
          <div class={`inline-flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br ${tool.gradient} text-white text-lg mb-3 shadow-sm`}>
            {tool.icon}
          </div>
          <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition text-sm">{tool.name}</h3>
          <p class="text-xs text-gray-500 mt-1 leading-relaxed">{tool.desc}</p>
          <div class="mt-3 text-xs font-semibold text-blue-600 flex items-center gap-1">
            Use Tool <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- CATEGORY SECTIONS — Dynamic -->
{categoriesWithUrls.map((cat) => (
  <section class={`py-16 border-t ${categoryBg[cat.name] || 'bg-white border-gray-100'}`}>
    <div class="max-w-6xl mx-auto px-4">

      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class={`w-10 h-10 rounded-xl bg-gradient-to-br ${categoryColors[cat.name] || 'from-gray-500 to-gray-600'} flex items-center justify-center text-lg shadow-sm`}>
            {cat.icon}
          </div>
          <div>
            <h2 class="text-xl font-extrabold text-gray-900">{cat.name}</h2>
            <p class="text-xs text-gray-500">{cat.tools.length} free tools</p>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {cat.tools.map(tool => (
          <a
            href={tool.href}
            class="group bg-white border border-gray-200 rounded-2xl p-5 hover:border-transparent hover:shadow-lg transition-all duration-200 flex flex-col"
          >
            <h3 class={`font-bold text-sm text-gray-900 transition ${categoryAccent[cat.name] || 'group-hover:text-blue-600'}`}>
              {tool.name}
            </h3>
            <p class="text-xs text-gray-500 mt-1.5 flex-1 leading-relaxed">{tool.description}</p>
            <div class={`mt-3 text-xs font-semibold flex items-center gap-1 ${categoryAccent[cat.name] || 'text-blue-600'}`}>
              Use Tool <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
))}

<!-- HOW IT WORKS -->
<section class="py-20 bg-gray-950 text-white">
  <div class="max-w-5xl mx-auto px-4 text-center">

    <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/20 text-blue-400 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
      Simple Process
    </div>

    <h2 class="text-3xl font-extrabold mb-4">How FreeAIToolz Works</h2>
    <p class="text-gray-400 mb-12 max-w-xl mx-auto">Three steps to get the results you need — no friction, no signup.</p>

    <div class="grid md:grid-cols-3 gap-8">
      {[
        { step: '01', icon: '🎯', title: 'Choose a Tool', desc: 'Select from AI writing, SEO, text utilities or developer tools.' },
        { step: '02', icon: '✏️', title: 'Enter Your Content', desc: 'Paste your text or fill in the required fields in seconds.' },
        { step: '03', icon: '⚡', title: 'Get Results Instantly', desc: 'Results appear immediately in your browser. Copy and use.' },
      ].map(step => (
        <div class="relative bg-white/5 border border-white/10 rounded-2xl p-6 text-left">
          <div class="text-4xl font-black text-white/10 mb-3">{step.step}</div>
          <div class="text-2xl mb-3">{step.icon}</div>
          <h3 class="font-bold text-white text-lg">{step.title}</h3>
          <p class="text-gray-400 text-sm mt-2 leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- TRUST STRIP -->
<section class="py-12 bg-white border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-4">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
      {[
        { icon: '🔒', label: 'Privacy First', desc: 'No data stored ever' },
        { icon: '⚡', label: 'Instant Results', desc: 'Browser-based speed' },
        { icon: '♾️', label: 'Unlimited Use', desc: 'No word limits' },
        { icon: '✅', label: 'No Signup', desc: 'Use immediately' },
      ].map(trust => (
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">{trust.icon}</span>
          <p class="font-bold text-gray-900 text-sm">{trust.label}</p>
          <p class="text-xs text-gray-500">{trust.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SEO CONTENT -->
<section class="py-16 bg-gray-50 border-t border-gray-100">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="text-2xl font-extrabold text-gray-900 mb-4">Free AI Tools, SEO Tools and Developer Utilities</h2>
    <p class="text-gray-600 leading-relaxed">
      FreeAIToolz provides a growing collection of free online tools designed for writers,
      marketers, developers and creators. Our platform includes AI writing tools like
      AI Humanizer and AI Content Detector, SEO utilities such as Schema Generator and
      Meta Description Generator, and developer tools including JSON Formatter and QR Code Generator.
    </p>
    <p class="text-gray-600 mt-4 leading-relaxed">
      All tools run directly in your browser and require no account or signup.
      Whether you need to optimize content, analyze data or generate code,
      FreeAIToolz helps you complete tasks faster using free and powerful utilities.
    </p>
  </div>
</section>

</BaseLayout>
