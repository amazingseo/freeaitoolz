---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import PasswordGenerator from '../../components/tools/PasswordGenerator';
const faqs = [
  { question: "Is this tool free?", answer: "Yes, completely free with no signup, no limits, no hidden charges." },
  { question: "Is my data private?", answer: "Yes. Everything runs in your browser. No data is stored on our servers." },
];
---
<ToolLayout title="Free Password Generator - No Signup Required" description="Generate strong random passwords with custom length and strength meter." keywords="password-generator, free online tool" toolName="Free Password Generator" toolCategory="Security Tool" faqs={faqs}>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <PasswordGenerator client:visible />
  </div>
</ToolLayout>
