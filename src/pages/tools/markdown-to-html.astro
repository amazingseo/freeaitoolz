---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import MarkdownToHtml from '../../components/tools/MarkdownToHtml';
const faqs = [
  { question: "Is this tool free?", answer: "Yes, completely free with no signup, no limits, no hidden charges." },
  { question: "Is my data private?", answer: "Yes. Everything runs in your browser. No data is stored on our servers." },
];
---
<ToolLayout title="Free Markdown to HTML Converter - No Signup Required" description="Convert Markdown to HTML with live preview and code output." keywords="markdown-to-html, free online tool" toolName="Free Markdown to HTML Converter" toolCategory="Developer Tool" faqs={faqs}>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <MarkdownToHtml client:visible />
  </div>
</ToolLayout>
