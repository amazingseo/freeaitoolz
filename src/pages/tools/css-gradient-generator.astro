---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import CssGradientGenerator from '../../components/tools/CssGradientGenerator';
const faqs = [
  { question: "Is this tool free?", answer: "Yes, completely free with no signup, no limits, no hidden charges." },
  { question: "Is my data private?", answer: "Yes. Everything runs in your browser. No data is stored on our servers." },
];
---
<ToolLayout title="Free CSS Gradient Generator - No Signup Required" description="Create CSS gradients with visual editor, presets, and Tailwind output." keywords="css-gradient-generator, free online tool" toolName="Free CSS Gradient Generator" toolCategory="Developer Tool" faqs={faqs}>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <CssGradientGenerator client:visible />
  </div>
</ToolLayout>
