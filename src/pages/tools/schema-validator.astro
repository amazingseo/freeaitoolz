---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaValidator from "../../components/tools/SchemaValidator";
---

<BaseLayout title="Free Structured Data Validator & Auto-Fixer | Schema.org JSON-LD Checker" description="Fetch your live URL, validate every JSON-LD schema block against schema.org rules, see exact errors with line numbers, and get Claude AI auto-fixed schema ready to copy-paste. Free.">
  <section class="relative overflow-hidden bg-gray-950 py-12 text-white">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/3 w-72 h-72 bg-blue-600 rounded-full opacity-10 blur-3xl"></div>
      <div class="absolute bottom-0 right-1/3 w-64 h-64 bg-violet-600 rounded-full opacity-10 blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white px-4 py-1.5 rounded-full text-xs font-bold mb-5 shadow-sm">SEO Tool</div>
      <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">Structured Data Validator & Auto-Fixer</h1>
      <p class="mt-4 text-gray-400 max-w-2xl mx-auto text-base leading-relaxed">Fetch your live page, find every broken JSON-LD schema, see exact errors, and get Claude AI-fixed schema ready to copy-paste — free, no signup.</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">Free Forever</span>
<span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">No Signup</span>
<span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">Live URL Fetch</span>
<span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">AI Auto-Fix</span>
      </div>
    </div>
  </section>
  <section class="py-10 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-800">
        <SchemaValidator client:load />
      </div>
      <div class="mt-12 pt-8 border-t border-gray-200 max-w-3xl mx-auto">
        <h3 class="text-base font-bold text-gray-900 mb-4">Complete Your AEO Workflow</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="/tools/aeo-geo-audit" class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all">
            <span class="text-xl mt-0.5">&#128202;</span>
            <div><p class="font-semibold text-sm text-gray-900 group-hover:text-blue-700">AEO &amp; GEO Audit Tool</p><p class="text-xs text-gray-500 mt-0.5">Full website AEO/GEO audit</p></div>
          </a>
          <a href="/tools/local-biz-visibility" class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all">
            <span class="text-xl mt-0.5">&#128269;</span>
            <div><p class="font-semibold text-sm text-gray-900 group-hover:text-blue-700">Local Business Visibility</p><p class="text-xs text-gray-500 mt-0.5">Test if AI engines know your business</p></div>
          </a>
          <a href="/tools/local-faq-schema" class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all">
            <span class="text-xl mt-0.5">&#10067;</span>
            <div><p class="font-semibold text-sm text-gray-900 group-hover:text-blue-700">FAQ &amp; Schema Generator</p><p class="text-xs text-gray-500 mt-0.5">Generate FAQPage + LocalBusiness schema</p></div>
          </a>
        </div>
      </div>
    </div>
  </section>
  <section class="py-12 bg-gray-950 text-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-gray-400 text-sm mb-4">Need done-for-you AEO strategy and implementation?</p>
      <a href="https://www.ai2flows.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white font-bold px-7 py-3.5 rounded-xl transition-all hover:scale-105 shadow-lg text-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Get Custom AI Solutions from AI2Flows
      </a>
    </div>
  </section>
</BaseLayout>
