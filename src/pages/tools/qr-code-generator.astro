---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import QrCodeGenerator from '../../components/tools/QrCodeGenerator';
const faqs = [
  { question: "Is this tool free?", answer: "Yes, completely free with no signup, no limits, no hidden charges." },
  { question: "Is my data private?", answer: "Yes. Everything runs in your browser. No data is stored on our servers." },
];
---
<ToolLayout title="Free QR Code Generator - No Signup Required" description="Generate QR codes for URLs, text, email, WiFi with custom colors." keywords="qr-code-generator, free online tool" toolName="Free QR Code Generator" toolCategory="Utility Tool" faqs={faqs}>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <QrCodeGenerator client:visible />
  </div>
</ToolLayout>
