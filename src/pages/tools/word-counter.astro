---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import WordCounter from '../../components/tools/WordCounter';
const faqs = [
  { question: "Is this tool free?", answer: "Yes, completely free with no signup, no limits, no hidden charges." },
  { question: "Is my data private?", answer: "Yes. Everything runs in your browser. No data is stored on our servers." },
];
---
<ToolLayout title="Free Word & Character Counter - No Signup Required" description="Count words, characters, sentences, paragraphs with reading time and keyword density." keywords="word-counter, free online tool" toolName="Free Word & Character Counter" toolCategory="Text Utility" faqs={faqs}>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <WordCounter client:visible />
  </div>
</ToolLayout>
