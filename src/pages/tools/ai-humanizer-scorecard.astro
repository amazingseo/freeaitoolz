---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import AIHumanizerScorecard from '../../components/tools/AIHumanizerScorecard';

const faqs = [
  {
    question: "What is an AI Humanizer Scorecard?",
    answer: "An AI Humanizer Scorecard analyzes your text and gives it a human score from 0-100. Instead of just rewriting text, it explains exactly why the text feels AI-generated by identifying specific patterns like overused transition words, repetitive sentence structures, and robotic phrasing."
  },
  {
    question: "How is this different from an AI detector?",
    answer: "AI detectors tell you IF content is AI-generated. Our scorecard tells you WHY it feels AI-generated and exactly which sentences or words are causing the problem. This helps you fix the specific issues rather than blindly rewriting everything."
  },
  {
    question: "What patterns does the tool detect?",
    answer: "The tool checks for overused AI transition words (Moreover, Furthermore, In conclusion), repetitive sentence openings, uniform paragraph lengths, excessive adverbs, passive voice overuse, and other linguistic patterns common in AI writing."
  },
  {
    question: "Is this tool free?",
    answer: "Yes, 100% free with no signup. The analysis runs entirely in your browser using JavaScript — no API calls, no data sent to servers."
  },
  {
    question: "What score should I aim for?",
    answer: "Aim for a score of 75 or above. Scores above 85 are considered strongly human. Below 50 means the text has many AI patterns that need attention before publishing."
  }
];
---

<ToolLayout
  title="AI Humanizer Scorecard - Score & Fix AI Text Patterns Free"
  description="Get a human score for your AI-generated text. Identifies overused transitions, robotic phrases, and AI patterns with specific fixes. Free, instant, no signup."
  keywords="AI humanizer scorecard, AI writing score, detect AI patterns, humanize AI text checker, AI content score, AI writing patterns"
  toolName="AI Humanizer Scorecard"
  toolCategory="AI Writing Tool"
  faqs={faqs}
>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <AIHumanizerScorecard client:visible />
  </div>

  <div class="mt-12 max-w-3xl mx-auto">
    <article class="prose prose-gray max-w-none">
      <h2 class="text-2xl font-bold text-gray-900">Why Your AI Text Feels Robotic (And How to Fix It)</h2>
      <p>Most AI humanizer tools just rewrite your text without explaining what was wrong. Our scorecard takes a different approach — it audits your content for the specific linguistic patterns that make AI writing detectable, and gives you actionable feedback on exactly what to fix.</p>

      <h3 class="text-xl font-bold text-gray-900 mt-8">Common AI Writing Patterns We Detect</h3>
      <p>AI models like ChatGPT and Claude tend to overuse certain transition words (Moreover, Furthermore, In conclusion), write in uniform sentence lengths with little variation, favor passive voice constructions, and use generic filler phrases. These patterns are statistically detectable and our tool flags each one with its frequency count.</p>

      <h3 class="text-xl font-bold text-gray-900 mt-8">How the Score is Calculated</h3>
      <p>The human score starts at 100 and deductions are made for each detected pattern based on its severity and frequency. Overused transition words, repetitive sentence starters, and uniform paragraph lengths are weighted heavily. Minor issues like occasional passive voice have smaller impact. The final score gives you a clear benchmark to work toward.</p>
    </article>

    <div class="mt-12 pt-8 border-t border-gray-200">
      <h3 class="text-lg font-bold text-gray-900 mb-4">Related Free Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/tools/ai-humanizer" class="tool-card group">
          <span class="text-2xl">✍️</span>
          <h4 class="font-semibold text-gray-900 group-hover:text-blue-600 mt-2">AI Humanizer</h4>
          <p class="text-sm text-gray-600 mt-1">Rewrite AI text to sound human</p>
        </a>
        <a href="/tools/ai-content-detector" class="tool-card group">
          <span class="text-2xl">🔍</span>
          <h4 class="font-semibold text-gray-900 group-hover:text-blue-600 mt-2">AI Content Detector</h4>
          <p class="text-sm text-gray-600 mt-1">Check if text was written by AI</p>
        </a>
        <a href="/tools/ai-paraphraser" class="tool-card group">
          <span class="text-2xl">🔄</span>
          <h4 class="font-semibold text-gray-900 group-hover:text-blue-600 mt-2">AI Paraphraser</h4>
          <p class="text-sm text-gray-600 mt-1">Rewrite text with multiple styles</p>
        </a>
      </div>
    </div>
  </div>
</ToolLayout>
