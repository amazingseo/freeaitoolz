---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import RobotsTxtGenerator from '../../components/tools/RobotsTxtGenerator';
const faqs = [
  { question: "Is this tool free?", answer: "Yes, completely free with no signup, no limits, no hidden charges." },
  { question: "Is my data private?", answer: "Yes. Everything runs in your browser. No data is stored on our servers." },
];
---
<ToolLayout title="Free Robots.txt Generator - No Signup Required" description="Generate robots.txt with GPTBot and AI crawler blocking support." keywords="robots-txt-generator, free online tool" toolName="Free Robots.txt Generator" toolCategory="SEO Tool" faqs={faqs}>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <RobotsTxtGenerator client:visible />
  </div>
</ToolLayout>
