---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    name: 'AI Writing Tools',
    icon: '✍️',
    desc: 'AI-powered writing and content tools',
    tools: [
      { name: 'AI Humanizer', desc: 'Transform AI text into natural human writing', href: '/tools/ai-humanizer', icon: '✍️', badge: 'Popular' },
      { name: 'AI Content Detector', desc: 'Check if text was written by AI', href: '/tools/ai-content-detector', icon: '🔍' },
      { name: 'AI Paraphraser', desc: 'Rewrite text with multiple styles', href: '/tools/ai-paraphraser', icon: '🔄' },
      { name: 'AI Email Writer', desc: 'Generate professional emails instantly', href: '/tools/ai-email-writer', icon: '📧' }
    ]
  },
  {
    name: 'SEO Tools',
    icon: '🔍',
    desc: 'Essential tools for SEO optimization',
    tools: [
      { name: 'Meta Description Generator', desc: 'Create SEO meta descriptions', href: '/tools/meta-description-generator', icon: '🏷️' },
      { name: 'Schema Markup Generator', desc: 'Generate JSON-LD structured data', href: '/tools/schema-markup-generator', icon: '🔧' },
      { name: 'Robots.txt Generator', desc: 'Generate robots.txt for search engines', href: '/tools/robots-txt-generator', icon: '🤖' },
      { name: 'Website Speed Checker', desc: 'Analyze Core Web Vitals and performance', href: '/tools/website-speed-checker', icon: '⚡' }
    ]
  },
  {
    name: 'Text Utilities',
    icon: '📝',
    desc: 'Basic text editing and formatting tools',
    tools: [
      { name: 'Word Counter', desc: 'Count words, characters and reading time', href: '/tools/word-counter', icon: '🔢' },
      { name: 'Case Converter', desc: 'Convert text to multiple case styles', href: '/tools/case-converter', icon: '🔤' },
      { name: 'Lorem Ipsum Generator', desc: 'Generate placeholder text', href: '/tools/lorem-ipsum-generator', icon: '📄' },
      { name: 'Markdown to HTML', desc: 'Convert markdown to HTML', href: '/tools/markdown-to-html', icon: '📝' }
    ]
  },
  {
    name: 'Developer Tools',
    icon: '⚡',
    desc: 'Developer and coding utilities',
    tools: [
      { name: 'JSON Formatter', desc: 'Format and validate JSON', href: '/tools/json-formatter', icon: '📋' },
      { name: 'Base64 Encoder/Decoder', desc: 'Encode and decode Base64', href: '/tools/base64-encoder-decoder', icon: '🔒' },
      { name: 'CSS Gradient Generator', desc: 'Visual CSS gradient builder', href: '/tools/css-gradient-generator', icon: '🎨' },
      { name: 'Password Generator', desc: 'Generate strong passwords', href: '/tools/password-generator', icon: '🔑' },
      { name: 'QR Code Generator', desc: 'Create QR codes with custom colors', href: '/tools/qr-code-generator', icon: '📱' }
    ]
  }
];

/* total tools */

const totalTools = categories.reduce((sum, c) => sum + c.tools.length, 0);

/* SEO schema */

const toolListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "FreeAIToolz Tool Directory",
  "numberOfItems": totalTools
};
---

<BaseLayout
title={`${totalTools}+ Free AI, SEO & Developer Tools | FreeAIToolz`}
description={`Browse ${totalTools}+ free online tools including AI writing tools, SEO tools, developer utilities and text tools. No signup required.`}
keywords="free ai tools, free seo tools, online developer tools, text utilities"
schema={toolListSchema}
breadcrumbs={[
  { label: "Home", url: "/" },
  { label: "Tools" }
]}
>

<section class="py-14">

<div class="max-w-7xl mx-auto px-4 sm:px-6">

<!-- Hero -->

<div class="text-center mb-12">

<h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900">

All Free Tools

</h1>

<p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">

Browse {totalTools}+ powerful AI tools, SEO tools and developer utilities — all completely free and running directly in your browser.

</p>

</div>


<!-- Discovery Search -->

<div class="max-w-3xl mx-auto mb-14">

<input
type="text"
placeholder="Search tools... (AI Humanizer, JSON Formatter, QR Code Generator)"
class="w-full border border-gray-200 rounded-xl px-5 py-3"
/>

</div>


<!-- Categories -->

{categories.map(cat => (

<div class="mb-16">

<div class="flex items-center gap-3 mb-6">

<span class="text-2xl">{cat.icon}</span>

<div>

<h2 class="text-2xl font-bold text-gray-900">

{cat.name}

</h2>

<p class="text-sm text-gray-500">

{cat.desc}

</p>

</div>

</div>


<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

{cat.tools.map(tool => (

<a
href={tool.href}
class="group border rounded-xl p-5 hover:border-blue-500 hover:shadow-md transition-all flex flex-col"
>

<div class="flex items-center justify-between mb-3">

<span class="text-2xl">{tool.icon}</span>

{tool.badge && (

<span class="text-xs font-bold bg-blue-100 text-blue-600 px-2 py-1 rounded-full">

{tool.badge}

</span>

)}

</div>

<h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600">

{tool.name}

</h3>

<p class="mt-2 text-sm text-gray-500 flex-1">

{tool.desc}

</p>

<div class="mt-4 text-sm font-semibold text-blue-600 flex items-center gap-1">

Use Tool

<span class="group-hover:translate-x-1 transition-transform">→</span>

</div>

</a>

))}

</div>

</div>

))}

</div>

</section>

</BaseLayout>
