---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    name: 'AI Writing Tools',
    desc: 'AI-powered tools for content creation, editing, and optimization',
    icon: '✍️',
    tools: [
      { name: 'AI Humanizer', desc: 'Transform AI text into natural human writing', href: '/tools/ai-humanizer', icon: '✍️', badge: 'Popular' },
      { name: 'AI Content Detector', desc: 'Check if text was written by AI with confidence scores', href: '/tools/ai-content-detector', icon: '🔍', badge: 'New' },
      { name: 'AI Paraphraser', desc: 'Rewrite text with 6 different tones and styles', href: '/tools/ai-paraphraser', icon: '🔄', badge: 'Unlimited' },
      { name: 'AI Email Writer', desc: 'Generate professional emails for any business situation', href: '/tools/ai-email-writer', icon: '📧', badge: 'Business' },
    ]
  },
  {
    name: 'SEO Tools',
    desc: 'Essential tools for search engine optimization and technical SEO',
    icon: '🔍',
    tools: [
      { name: 'Meta Description Generator', desc: 'Create SEO-optimized meta descriptions and title tags', href: '/tools/meta-description-generator', icon: '🏷️', badge: 'SEO' },
      { name: 'Schema Markup Generator', desc: 'Build JSON-LD structured data for rich results', href: '/tools/schema-markup-generator', icon: '🔧', badge: 'New' },
      { name: 'Website Speed Checker', desc: 'Test Core Web Vitals and page performance scores', href: '/tools/website-speed-checker', icon: '⚡', badge: 'New' },
    ]
  },
];
---

<BaseLayout
  title="Free AI & SEO Tools Online - Complete Collection | FreeAIToolz"
  description="Browse our complete collection of free AI writing tools and SEO tools. AI Humanizer, Content Detector, Paraphraser, Schema Generator, Speed Checker and more. No signup required."
  keywords="free AI tools, SEO tools, AI writing tools, free online tools, schema generator, speed checker"
>
  <section class="py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight">All Free Tools</h1>
        <p class="mt-4 text-lg text-gray-500 max-w-xl mx-auto">Every tool is free, requires no signup, and works instantly in your browser.</p>
      </div>

      {categories.map(cat => (
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">{cat.icon}</span>
            <div>
              <h2 class="text-2xl font-extrabold text-gray-900">{cat.name}</h2>
              <p class="text-sm text-gray-500">{cat.desc}</p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
            {cat.tools.map(tool => (
              <a href={tool.href} class="tool-card group flex flex-col">
                <div class="flex items-start justify-between mb-3">
                  <span class="text-2xl">{tool.icon}</span>
                  <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">{tool.badge}</span>
                </div>
                <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{tool.name}</h3>
                <p class="mt-1.5 text-sm text-gray-500 flex-1">{tool.desc}</p>
                <div class="mt-4 text-sm font-bold text-blue-600 flex items-center gap-1">
                  Use Free <span class="group-hover:translate-x-1 transition-transform">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
