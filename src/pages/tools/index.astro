---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { toolCategories } from '../../data/tools'
import ToolSearch from '../../components/ToolSearch.astro'

/* count total tools */

let totalTools = 0

toolCategories.forEach(cat=>{
  totalTools += cat.tools.length
})

const schema = {
 "@context":"https://schema.org",
 "@type":"ItemList",
 "name":"FreeAIToolz Tool Directory",
 "numberOfItems": totalTools
}
---

<BaseLayout
title={`${totalTools}+ Free AI, SEO & Developer Tools | FreeAIToolz`}
description={`Browse ${totalTools}+ powerful free online tools including AI writing tools, SEO tools, developer tools and utilities.`}
schema={schema}
breadcrumbs={[
{label:"Home",url:"/"},
{label:"Tools"}
]}
>

<section class="max-w-7xl mx-auto px-4 py-16">

<div class="text-center mb-12">

<h1 class="text-4xl font-bold text-gray-900 mb-4">
All Free Tools
</h1>

<p class="text-gray-600 max-w-2xl mx-auto">
Browse {totalTools}+ powerful AI tools, SEO tools and developer utilities — all completely free.
</p>

</div>
<!-- ADD SEARCH HERE -->
<ToolSearch />

<!-- CATEGORY SECTIONS -->

{toolCategories.map(category => (

<div class="mb-14">

<div class="flex items-center gap-3 mb-6">

<span class="text-2xl">{category.icon}</span>

<h2 class="text-2xl font-bold text-gray-900">
{category.name}
</h2>

</div>


<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

{category.tools.map(tool => (

<a
href={`/tools/${tool.slug}`}
class="border rounded-xl p-5 hover:shadow-md hover:border-blue-500 transition flex flex-col"
>

<h3 class="text-lg font-semibold text-gray-900">
{tool.name}
</h3>

<p class="text-sm text-gray-500 mt-2 flex-1">
{tool.description}
</p>

<div class="mt-4 text-blue-600 font-semibold text-sm">
Use Tool →
</div>

</a>

))}

</div>

</div>

))}

</section>

</BaseLayout>
