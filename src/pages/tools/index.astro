---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    name: 'AI Writing Tools',
    tools: [
      { name: 'AI Humanizer', desc: 'Transform AI text into natural human writing', href: '/tools/ai-humanizer', icon: '✍️', ready: true },
      { name: 'AI Content Detector', desc: 'Check if text was written by AI', href: '/tools/ai-content-detector', icon: '🔍', ready: false },
      { name: 'AI Paraphraser', desc: 'Rewrite text with different words and style', href: '/tools/ai-paraphraser', icon: '🔄', ready: false },
      { name: 'AI Email Writer', desc: 'Generate professional emails instantly', href: '/tools/ai-email-writer', icon: '📧', ready: false },
    ]
  },
  {
    name: 'SEO Tools',
    tools: [
      { name: 'Meta Description Generator', desc: 'Create SEO-optimized meta descriptions', href: '/tools/meta-description-generator', icon: '🏷️', ready: false },
      { name: 'SEO Title Generator', desc: 'Generate click-worthy SEO titles', href: '/tools/seo-title-generator', icon: '📝', ready: false },
      { name: 'Schema Markup Generator', desc: 'Create structured data for rich results', href: '/tools/schema-markup-generator', icon: '🔧', ready: false },
    ]
  },
];
---

<BaseLayout
  title="Free AI Tools Online - Complete Collection | FreeAIToolz"
  description="Browse our complete collection of free AI-powered tools for writing, SEO, and content creation. No signup required, no limits."
  keywords="free AI tools, AI writing tools, SEO tools, online tools free, AI-powered tools"
>
  <section class="py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">All Free AI Tools</h1>
        <p class="mt-4 text-lg text-gray-600 max-w-xl mx-auto">Every tool is free, requires no signup, and works instantly in your browser.</p>
      </div>

      {categories.map(cat => (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{cat.name}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {cat.tools.map(tool => (
              <a href={tool.ready ? tool.href : '#'} class={`tool-card group ${!tool.ready ? 'opacity-60 cursor-default' : ''}`}>
                <div class="flex items-start justify-between mb-3">
                  <span class="text-3xl">{tool.icon}</span>
                  {!tool.ready && <span class="text-xs font-medium px-2 py-1 rounded-full bg-gray-100 text-gray-500">Coming Soon</span>}
                  {tool.ready && <span class="text-xs font-medium px-2 py-1 rounded-full bg-green-100 text-green-700">Live</span>}
                </div>
                <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{tool.name}</h3>
                <p class="mt-1 text-sm text-gray-600">{tool.desc}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
