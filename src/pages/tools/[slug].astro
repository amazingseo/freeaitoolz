---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getAllTools, getToolsByCategory } from "../../lib/tools"

export async function getStaticPaths() {
const tools = getAllTools()

return tools.map(tool => ({
params: { slug: tool.slug },
props: { tool }
}))

}

const { tool } = Astro.props
const relatedTools = getToolsByCategory(tool.category)
  .filter(t => t.slug !== tool.slug)
  .slice(0,4)
const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": tool.name,
  "applicationCategory": tool.category,
  "operatingSystem": "All",
  "description": tool.description,
  "url": `https://freeaitoolz.com/tools/${tool.slug}`,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}
---
<section class="max-w-6xl mx-auto px-4 py-16">

<h2 class="text-2xl font-bold text-gray-900 mb-6">
Related Tools
</h2>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

{relatedTools.map(t => (

<a
href={`/tools/${t.slug}`}
class="border rounded-xl p-5 hover:shadow-md hover:border-blue-500 transition flex flex-col"
>

<h3 class="font-semibold text-gray-900">
{t.name}
</h3>

<p class="text-sm text-gray-500 mt-2 flex-1">
{t.description}
</p>

<div class="mt-4 text-blue-600 font-semibold text-sm">
Use Tool →
</div>

</a>

))}

</div>

</section>
---
<BaseLayout
title={`${tool.name} | FreeAIToolz`}
description={tool.description}
schema={toolSchema}
breadcrumbs={[
{ label: "Home", url: "/" },
{ label: "Tools", url: "/tools" },
{ label: tool.name }
]}
>
<section id="tool" class="max-w-5xl mx-auto px-4 py-16">

<h1 class="text-4xl font-bold text-gray-900 mb-6">
{tool.name}
</h1>
<p class="inline-block text-xs bg-blue-50 text-blue-600 px-3 py-1 rounded-full mb-4">
{tool.category}
</p>
<p class="text-gray-600 mb-10">
{tool.description}
</p>

<div class="border border-gray-200 rounded-xl p-8 bg-white shadow-sm">

<p class="text-gray-500">
Tool interface will go here.
</p>

</div>

</section>

</BaseLayout>
