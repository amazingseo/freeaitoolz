---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getAllTools, getToolsByCategory } from "../../lib/tools"

export async function getStaticPaths() {
  const tools = getAllTools()
  return tools.map(tool => ({
    params: { slug: tool.slug },
    props: { tool }
  }))
}

const { tool } = Astro.props
const relatedTools = getToolsByCategory(tool.category)
  .filter(t => t.slug !== tool.slug)
  .slice(0, 4)
  .map(t => ({ ...t, url: `/tools/${t.slug}` }))
const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": tool.name,
  "applicationCategory": tool.category,
  "operatingSystem": "All",
  "description": tool.description,
  "url": `https://freeaitoolz.com/tools/${tool.slug}`,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}
---

<BaseLayout
  title={`${tool.name} | FreeAIToolz`}
  description={tool.description}
  schema={toolSchema}
  breadcrumbs={[
    { label: "Home", url: "/" },
    { label: "Tools", url: "/tools" },
    { label: tool.name }
  ]}
>

  <!-- ✅ SECTION 1: Tool Header + Interface — bg-white -->
  <section id="tool" class="w-full bg-white">
    <div class="max-w-5xl mx-auto px-4 py-16">

      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        {tool.name}
      </h1>

      <p class="inline-block text-xs bg-blue-50 text-blue-600 px-3 py-1 rounded-full mb-6">
        {tool.category}
      </p>

      <div class="text-gray-600 mb-10 max-w-3xl space-y-4">
        <p>
          Use our free <strong>{tool.name}</strong> tool online to quickly and easily
          {tool.description.toLowerCase()}. This tool works instantly in your browser
          and requires no signup or installation.
        </p>
        <p>
          FreeAIToolz provides powerful browser-based utilities designed for speed,
          privacy, and simplicity. Whether you're a developer, marketer, or content
          creator, this tool helps you complete tasks faster without needing paid software.
        </p>
      </div>

      <div class="border border-gray-200 rounded-xl p-8 bg-white shadow-sm">
        <p class="text-gray-500">Tool interface will go here.</p>
      </div>

    </div>
  </section>

  <!-- ✅ SECTION 2: Quick Facts — bg-gray-50 -->
  <section class="w-full bg-gray-50 border-t border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-12">

      <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/>
        </svg>
        Quick Facts
      </h2>

      <div class="divide-y divide-gray-200">

        <div class="flex items-center justify-between py-3">
          <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-4.75M16 3l5 5-9 9H7v-5l9-9z"/>
            </svg>
            Tool Name
          </span>
          <span class="text-sm font-semibold text-gray-800">{tool.name}</span>
        </div>

        <div class="flex items-center justify-between py-3">
          <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Category
          </span>
          <span class="text-sm font-semibold text-blue-600 bg-blue-50 px-3 py-1 rounded-full">{tool.category}</span>
        </div>

        <div class="flex items-center justify-between py-3">
          <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.12-3 2.5S10.343 13 12 13s3 1.12 3 2.5S13.657 18 12 18m0-10V6m0 12v-2"/>
            </svg>
            Price
          </span>
          <span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">✓ Free</span>
        </div>

        <div class="flex items-center justify-between py-3">
          <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Platform
          </span>
          <span class="text-sm font-semibold text-gray-800">Browser Based</span>
        </div>

        <div class="flex items-center justify-between py-3">
          <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/>
            </svg>
            Login Required
          </span>
          <span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">✓ No</span>
        </div>

        <div class="flex items-center justify-between py-3">
          <span class="flex items-center gap-2 text-sm font-medium text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Processing
          </span>
          <span class="text-sm font-semibold text-gray-800">Instant</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ✅ SECTION 3: How to Use — bg-white -->
  <section class="w-full bg-white">
    <div class="max-w-5xl mx-auto px-4 py-16">

      <h2 class="text-2xl font-bold text-gray-900 mb-6">
        How to Use {tool.name}
      </h2>

      <ol class="list-decimal pl-6 space-y-3 text-gray-600">
        <li>Enter your text or input into the tool.</li>
        <li>Click the process or generate button.</li>
        <li>Review the results instantly.</li>
        <li>Copy or download the output for your use.</li>
      </ol>

    </div>
  </section>

 <!-- ✅ SECTION 4: Related Tools — bg-gray-50 -->
<section class="w-full bg-gray-50 border-t border-gray-100">
  <div class="max-w-5xl mx-auto px-4 py-16">

    <h2 class="text-2xl font-bold text-gray-900 mb-6">
      Related Tools
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {relatedTools.map(t => (
        
          href={t.url}
          class="border border-gray-200 bg-white rounded-xl p-5 hover:shadow-md hover:border-blue-500 transition flex flex-col"
        >
          <h3 class="font-semibold text-gray-900">{t.name}</h3>
          <p class="text-sm text-gray-500 mt-2 flex-1">{t.description}</p>
          <div class="mt-4 text-blue-600 font-semibold text-sm">Use Tool →</div>
        </a>
      ))}
    </div>

  </div>
</section>

</BaseLayout>
