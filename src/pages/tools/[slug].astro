---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { toolCategories } from '../../data/tools'

const { slug } = Astro.params

/* find tool */

let currentTool = null
let currentCategory = null

for (const category of toolCategories) {
  const found = category.tools.find(t => t.slug === slug)

  if (found) {
    currentTool = found
    currentCategory = category
    break
  }
}

/* 404 fallback */

if (!currentTool) {
  return Astro.redirect('/tools')
}
---

<BaseLayout
  title={`${currentTool.name} | FreeAIToolz`}
  description={currentTool.description}
  breadcrumbs={[
    { label: "Home", url: "/" },
    { label: "Tools", url: "/tools" },
    { label: currentTool.name }
  ]}
>

<section class="max-w-4xl mx-auto px-4 py-16">

<h1 class="text-4xl font-bold text-gray-900 mb-4">
{currentTool.name}
</h1>

<p class="text-gray-600 mb-10">
{currentTool.description}
</p>

<div class="bg-white border rounded-xl p-8 shadow-sm">

<p class="text-gray-500">
Tool interface will go here.
</p>

</div>

</section>

</BaseLayout>
