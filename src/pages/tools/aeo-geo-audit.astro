---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import AeoGeoAuditTool from "../../components/tools/AeoGeoAuditTool";
---

<BaseLayout
  title="Free AEO & GEO Audit Tool — AI Visibility Checker for ChatGPT, Claude & Perplexity"
  description="Check if your site is optimized for ChatGPT, Claude, Perplexity & Google AI Overviews. Real schema analysis, live robots.txt check, and actual AI visibility test. Free, no signup."
>

  <section class="relative overflow-hidden bg-gray-950 py-12 text-white">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/3 w-72 h-72 bg-blue-600 rounded-full opacity-10 blur-3xl"></div>
      <div class="absolute bottom-0 right-1/3 w-64 h-64 bg-violet-600 rounded-full opacity-10 blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white px-4 py-1.5 rounded-full text-xs font-bold mb-5 shadow-sm">SEO Tool</div>
      <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">Free AEO &amp; GEO Audit Tool</h1>
      <p class="mt-4 text-gray-400 max-w-2xl mx-auto text-base leading-relaxed">Check if your site is optimized for ChatGPT, Claude, Perplexity &amp; Google AI Overviews. Real schema analysis, live robots.txt check, and actual AI visibility test. No signup required.</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">Free Forever</span>
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">No Signup</span>
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">Real Data</span>
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">Live AI Test</span>
      </div>
    </div>
  </section>

  <section class="py-10 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-800">
        <AeoGeoAuditTool client:load />
      </div>
    </div>
  </section>

  <section class="w-full bg-gray-50 border-t border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/></svg>
        Quick Facts
      </h2>
      <div class="divide-y divide-gray-200">
        <div class="flex items-center justify-between py-3"><span class="text-sm font-medium text-gray-600">Tool Name</span><span class="text-sm font-semibold text-gray-800">AEO &amp; GEO Audit Tool</span></div>
        <div class="flex items-center justify-between py-3"><span class="text-sm font-medium text-gray-600">Category</span><span class="text-sm font-semibold text-blue-600 bg-blue-50 px-3 py-1 rounded-full">SEO Tools</span></div>
        <div class="flex items-center justify-between py-3"><span class="text-sm font-medium text-gray-600">Price</span><span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">Free</span></div>
        <div class="flex items-center justify-between py-3"><span class="text-sm font-medium text-gray-600">Platform</span><span class="text-sm font-semibold text-gray-800">Browser Based</span></div>
        <div class="flex items-center justify-between py-3"><span class="text-sm font-medium text-gray-600">Login Required</span><span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">No</span></div>
        <div class="flex items-center justify-between py-3"><span class="text-sm font-medium text-gray-600">Daily Limit</span><span class="text-sm font-semibold text-gray-800">5 audits / day</span></div>
        <div class="flex items-center justify-between py-3"><span class="text-sm font-medium text-gray-600">AI Model</span><span class="text-sm font-semibold text-gray-800">Claude Haiku 4.5</span></div>
      </div>
    </div>
  </section>

  <section class="w-full bg-white">
    <div class="max-w-5xl mx-auto px-4 py-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">How to Use the AEO &amp; GEO Audit Tool</h2>
      <ol class="list-decimal pl-6 space-y-3 text-gray-600">
        <li>Enter your website URL (e.g. https://yoursite.com) in the input field above.</li>
        <li>Click <strong>Run Audit</strong> — the tool fetches your live page HTML and robots.txt in real time.</li>
        <li>Review your <strong>AEO Score</strong> (content structure for AI citations) and <strong>GEO Score</strong> (AI bot access and entity signals).</li>
        <li>Click any failed check to see the exact fix required.</li>
        <li>Open the <strong>AI Visibility</strong> tab to see whether Claude AI already knows your brand.</li>
      </ol>
    </div>
  </section>

  <section class="w-full bg-gray-50 border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Frequently Asked Questions</h2>
      <div class="space-y-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">What is AEO (Answer Engine Optimization)?</h3>
          <p class="text-gray-600 text-sm leading-relaxed">AEO is the practice of structuring your content so AI-powered answer engines like ChatGPT, Perplexity, Claude, and Google AI Overviews can extract, cite, and attribute your site as a trusted source. It focuses on schema markup, question-format headings, E-E-A-T signals, and content structure.</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">What is GEO (Generative Engine Optimization)?</h3>
          <p class="text-gray-600 text-sm leading-relaxed">GEO ensures AI crawlers can actually access your site and that your brand entity is well-defined across the web. This includes allowing GPTBot, ClaudeBot, PerplexityBot, and Google-Extended in your robots.txt, having Organization schema, and building a consistent brand presence.</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">How is this different from a regular SEO audit?</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Traditional SEO audits check ranking factors for Google's blue-link results. This tool checks the 23 signals that determine whether AI engines cite you in their generated answers — a completely different and increasingly important visibility channel.</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Is the AI Visibility test really live?</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Yes. The AI Visibility tab sends 3 real queries to the Claude Haiku 4.5 API and checks whether your brand is mentioned in the responses. Each check costs approximately $0.0023 in API tokens (~75 input + ~450 output tokens).</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Why is there a 5 audits per day limit?</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Each audit makes live API calls to fetch your page, check robots.txt, and query the Claude AI. The limit keeps the tool free for everyone. Your limit resets at midnight every day.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
