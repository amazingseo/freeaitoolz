--
export const prerender = true;-
import BaseLayout from '../../layouts/BaseLayout.astro';
import AeoGeoAuditTool from '../../components/tools/AeoGeoAuditTool';
---

<BaseLayout
  title="Free AEO & GEO Audit Tool — AI Visibility & Answer Engine Checker"
  description="Free AEO and GEO audit tool. Check if your site is optimized for ChatGPT, Claude, Perplexity & Google AI Overviews. Real robots.txt analysis, schema detection, and live AI visibility test."
>

  <section class="relative overflow-hidden bg-gray-950 py-12 text-white">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/3 w-72 h-72 bg-blue-600 rounded-full opacity-10 blur-3xl"></div>
      <div class="absolute bottom-0 right-1/3 w-64 h-64 bg-violet-600 rounded-full opacity-10 blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white px-4 py-1.5 rounded-full text-xs font-bold mb-5 shadow-sm">
        SEO Tool
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">
        Free AEO &amp; GEO Audit Tool
      </h1>
      <p class="mt-4 text-gray-400 max-w-2xl mx-auto text-base leading-relaxed">
        Check if your site is optimized for ChatGPT, Claude, Perplexity &amp; Google AI Overviews.
        Real schema analysis, live robots.txt check, and actual AI visibility test. No signup required.
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">✅ Free Forever</span>
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">🔒 No Signup</span>
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">⚡ Real Data</span>
        <span class="inline-flex items-center gap-1.5 bg-white/5 border border-white/10 text-gray-300 text-xs font-medium px-3 py-1.5 rounded-full">🤖 Live AI Test</span>
      </div>
    </div>
  </section>

  <section class="py-10 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-800">
        <AeoGeoAuditTool client:load />
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">What is AEO and GEO?</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Answer Engine Optimization (AEO) is the practice of structuring your content so AI-powered answer engines
        like ChatGPT, Perplexity, Claude, and Google AI Overviews can extract, cite, and attribute your brand as a
        trusted source. Generative Engine Optimization (GEO) extends this further — ensuring AI crawlers can access
        your site, your brand entity is well-defined, and your content appears in AI-generated answers.
      </p>
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Why AEO and GEO Matter in 2025</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        AI-sourced sessions jumped 527% in 2025, with LLM-generated traffic converting at 27% compared to 2.1%
        from traditional search. Meanwhile, organic click-through rates dropped by over half when AI summaries appear.
        This tool checks 23 real signals that determine whether AI engines cite your site or ignore it.
      </p>
      <h2 class="text-2xl font-bold text-gray-900 mb-3">What This Tool Checks</h2>
      <p class="text-gray-600 leading-relaxed">
        The audit fetches your live page HTML and robots.txt, then analyzes FAQ and Article schema markup,
        question-format headings, author and date signals, E-E-A-T indicators, AI bot permissions for GPTBot,
        ClaudeBot, PerplexityBot and Google-Extended, Organization schema, sitemap presence, and canonical setup.
        The AI Visibility tab actually queries Claude AI and reports whether your brand is recognized.
      </p>
    </div>
  </section>

</BaseLayout>
