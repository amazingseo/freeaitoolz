---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AeoGeoAuditTool from '../../components/tools/AeoGeoAuditTool';

const title = "Free AEO & GEO Audit Tool — AI Visibility & Answer Engine Checker";
const description = "Free AEO and GEO audit tool. Check if your site is optimized for ChatGPT, Claude, Perplexity & Google AI Overviews. Real robots.txt analysis, schema detection, and live AI visibility test.";
const category = "SEO Tools";
const toolName = "AEO & GEO Audit Tool";
---

<BaseLayout title={title} description={description}>
  <!-- Hero section matching site pattern -->
  <div class="bg-gray-950 text-white py-12 px-4 text-center">
    <div class="inline-flex items-center gap-2 bg-gray-900 border border-gray-800 rounded-full px-4 py-1.5 text-sm font-semibold text-blue-400 mb-5">
      SEO Tool
    </div>
    <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">{toolName}</h1>
    <p class="text-gray-400 max-w-2xl mx-auto text-base sm:text-lg leading-relaxed mb-6">
      Check if your site is optimized for ChatGPT, Claude, Perplexity &amp; Google AI Overviews.
      Real schema analysis, live robots.txt check, and actual AI visibility test.
    </p>
    <div class="flex flex-wrap justify-center gap-3 text-sm">
      <span class="bg-gray-900 border border-gray-800 rounded-full px-4 py-1.5 text-gray-300">✅ Free Forever</span>
      <span class="bg-gray-900 border border-gray-800 rounded-full px-4 py-1.5 text-gray-300">🔒 No Signup</span>
      <span class="bg-gray-900 border border-gray-800 rounded-full px-4 py-1.5 text-gray-300">⚡ Real Data</span>
      <span class="bg-gray-900 border border-gray-800 rounded-full px-4 py-1.5 text-gray-300">🤖 Live AI Test</span>
    </div>
  </div>

  <!-- Tool container -->
  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <AeoGeoAuditTool client:load />
    </div>
  </div>

  <!-- SEO content below tool -->
  <div class="max-w-3xl mx-auto px-4 pb-16">
    <div class="prose prose-gray max-w-none">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">What is AEO and GEO?</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Answer Engine Optimization (AEO) is the practice of structuring your content so AI-powered answer engines
        like ChatGPT, Perplexity, Claude, and Google AI Overviews can extract, cite, and attribute your brand as a
        trusted source. Generative Engine Optimization (GEO) extends this — ensuring AI crawlers can access your site,
        your brand entity is well-defined, and your content appears in AI-generated answers.
      </p>
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Why AEO and GEO Matter in 2025</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        AI-sourced sessions jumped 527% in 2025, with LLM-generated traffic converting at 27% compared to 2.1%
        from traditional search. Meanwhile, organic click-through rates dropped by over half when AI summaries appear.
        This tool checks 23+ real signals that determine whether AI engines cite your site or ignore it.
      </p>
      <h2 class="text-2xl font-bold text-gray-900 mb-3">What This Tool Checks</h2>
      <p class="text-gray-600 leading-relaxed">
        The audit fetches your live page HTML and robots.txt, then analyzes: FAQ and Article schema markup,
        question-format headings, author and date signals, E-E-A-T indicators, AI bot permissions (GPTBot,
        ClaudeBot, PerplexityBot, Google-Extended), Organization schema, sitemap presence, and canonical setup.
        The AI Visibility tab actually queries Claude and reports whether your brand is known.
      </p>
    </div>
  </div>
</BaseLayout>
