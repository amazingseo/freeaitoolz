---
export const prerender = true;
import ToolLayout from '../../layouts/ToolLayout.astro';
import CaseConverter from '../../components/tools/CaseConverter';
const faqs = [
  { question: "Is this tool free?", answer: "Yes, completely free with no signup, no limits, no hidden charges." },
  { question: "Is my data private?", answer: "Yes. Everything runs in your browser. No data is stored on our servers." },
];
---
<ToolLayout title="Free Case Converter - No Signup Required" description="Convert text to UPPERCASE, lowercase, Title Case, camelCase, snake_case and more." keywords="case-converter, free online tool" toolName="Free Case Converter" toolCategory="Text Utility" faqs={faqs}>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <CaseConverter client:visible />
  </div>
</ToolLayout>
