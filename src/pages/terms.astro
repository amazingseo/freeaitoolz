---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms and Conditions | FreeAIToolz"
  description="Terms and Conditions for using FreeAIToolz free AI tools."
>
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Terms and Conditions</h1>
    <p class="text-sm text-gray-500 mb-10">Last updated: March 2026</p>
    <div class="space-y-8">
      {[
        { title: '1. Acceptance of Terms', body: 'By accessing FreeAIToolz at freeaitoolz.com, you agree to these Terms. If you do not agree, please do not use our website.' },
        { title: '2. Use of Tools', body: 'Tools are provided as-is. You must not use them for illegal or harmful purposes, attempt to abuse our API, or conduct automated bulk usage without permission. You are responsible for content you submit.' },
        { title: '3. AI-Generated Content', body: 'AI output may be inaccurate or incomplete. Always review output before publishing. FreeAIToolz is not responsible for decisions made based on AI-generated content. You own the output generated using your inputs.' },
        { title: '4. Intellectual Property', body: 'The FreeAIToolz website, design, and code are owned by AI2Flows. You may not copy or reproduce any part without permission.' },
        { title: '5. Limitation of Liability', body: 'FreeAIToolz and AI2Flows are not liable for any damages arising from use of our tools. All tools are provided free of charge without guarantees of uptime or accuracy.' },
        { title: '6. Service Availability', body: 'We may modify, suspend, or discontinue any tool at any time without notice.' },
        { title: '7. Third-Party Links', body: 'We are not responsible for content, privacy practices, or terms of third-party websites linked from our platform.' },
        { title: '8. Changes to Terms', body: 'We may update these terms at any time. Continued use of the website after changes constitutes acceptance.' },
        { title: '9. Contact', body: 'For questions about these terms, contact us through ai2flows.com.' },
      ].map(section => (
        <div class="border-b border-gray-100 pb-8">
          <h2 class="text-lg font-bold text-gray-900 mb-2">{section.title}</h2>
          <p class="text-gray-600 leading-relaxed">{section.body}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
