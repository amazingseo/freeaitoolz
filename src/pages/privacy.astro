---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | FreeAIToolz"
  description="Privacy Policy for FreeAIToolz. Learn how we handle your data."
>
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Privacy Policy</h1>
    <p class="text-sm text-gray-500 mb-10">Last updated: March 2026</p>
    <div class="space-y-8">
      {[
        { title: '1. Overview', body: 'FreeAIToolz is committed to protecting your privacy. Most tools run entirely in your browser and do not require any personal information. We are built with a privacy-first approach.' },
        { title: '2. Information We Collect', body: 'We collect minimal data: anonymized usage analytics via Google Analytics, and text submitted to AI tools which is processed to generate results and never stored on our servers.' },
        { title: '3. How We Use Your Information', body: 'To provide and operate our free tools, improve the website and user experience, and monitor site performance.' },
        { title: '4. Third-Party Services', body: 'We use Anthropic (Claude API) and OpenAI to power AI tools, Google Analytics for anonymized usage data, and Vercel for hosting. Each operates under their own privacy policies.' },
        { title: '5. Data Retention', body: 'We do not store any content you submit to our tools. Text inputs are sent to AI providers to generate results only. Analytics data is retained for up to 26 months in anonymized form.' },
        { title: '6. Children\'s Privacy', body: 'FreeAIToolz is not directed at children under 13. We do not knowingly collect personal information from children.' },
        { title: '7. Changes to This Policy', body: 'We may update this Privacy Policy from time to time. Changes will be posted on this page with an updated date.' },
        { title: '8. Contact', body: 'For privacy questions, contact us through ai2flows.com.' },
      ].map(section => (
        <div class="border-b border-gray-100 pb-8">
          <h2 class="text-lg font-bold text-gray-900 mb-2">{section.title}</h2>
          <p class="text-gray-600 leading-relaxed">{section.body}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
